<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.22621.0</TargetPlatformMinVersion>
    <Platforms>x64</Platforms>
    <UseWinUI>true</UseWinUI>
    <WindowsAppSdkBootstrapInitialize>true</WindowsAppSdkBootstrapInitialize>
    <ApplicationIcon>Assets\emwaver.ico</ApplicationIcon>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <DefineConstants>$(DefineConstants);DISABLE_XAML_GENERATED_MAIN</DefineConstants>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- CI/dev shells may not have full VC toolchain installed; avoid vcmeta-based fingerprinting. -->
    <UseVCMetaManaged>false</UseVCMetaManaged>
    <XAMLFingerprint>false</XAMLFingerprint>
    <!-- Use in-proc XAML compiler (avoids net472 XamlCompiler.exe). -->
    <UseXamlCompilerExecutable>false</UseXamlCompilerExecutable>

    <!-- Help WinUI XamlCompiler find VC toolchain (for GenXbf). -->
    <!-- Use ProgramW6432 so this works under 32-bit MSBuild too. -->
    <VsInstallRoot Condition="'$(VsInstallRoot)' == '' and Exists('$(ProgramW6432)\Microsoft Visual Studio\18\Community')">$(ProgramW6432)\Microsoft Visual Studio\18\Community</VsInstallRoot>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260101001" />
    <PackageReference Include="ScintillaNET.Core" Version="3.6.51" />
    <PackageReference Include="Jint" Version="3.1.6" />
    <!-- Required for WinUI XAML compiler tasks under dotnet msbuild. -->
    <PackageReference Include="System.Security.Permissions" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="app.manifest" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Native\\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <!-- Place native DLLs in the app root so DllImport can find them. -->
      <TargetPath>%(Filename)%(Extension)</TargetPath>
    </None>
  </ItemGroup>

  <PropertyGroup>
    <!-- Default: do NOT compile the Rust DFU helper on developer machines.
         It requires a full MSVC+Windows SDK toolchain (and is flaky across shells).
         Instead, bundle a prebuilt helper exe (built in CI or on a known-good box).
         Set /p:BuildDfuHelper=true to build it locally. -->
    <BuildDfuHelper>false</BuildDfuHelper>
  </PropertyGroup>

  <!-- Bundle firmware + DFU helper (Rust) into the app output, mirroring macOS behavior. -->
  <Target Name="BundleFirmwareAndDfuHelper" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <_FirmwareSrc>..\\..\\firmware\\emwaver.bin</_FirmwareSrc>
      <_DfuHelperManifest>..\\..\\crates\\emwaver-dfu-helper\\Cargo.toml</_DfuHelperManifest>
      <_DfuHelperTarget>$(BaseIntermediateOutputPath)emwaver-dfu-helper\\target</_DfuHelperTarget>
      <_DfuHelperExe>$(_DfuHelperTarget)\\x86_64-pc-windows-msvc\\release\\emwaver-dfu-helper.exe</_DfuHelperExe>
      <_PrebuiltDfuHelper>Assets\\dfu\\emwaver-dfu-helper.exe</_PrebuiltDfuHelper>
    </PropertyGroup>

    <Error Condition="!Exists('$(_FirmwareSrc)')" Text="Missing bundled firmware at: $(_FirmwareSrc)" />

    <Message Text="[Bundle Firmware + DFU Helper] firmware_src=$(_FirmwareSrc)" Importance="high" />

    <!-- Copy firmware into app root output as emwaver.bin -->
    <Copy SourceFiles="$(_FirmwareSrc)" DestinationFiles="$(OutDir)emwaver.bin" SkipUnchangedFiles="false" />

    <!-- DFU helper: either copy a prebuilt exe, or (optionally) build it locally. -->

    <Message Condition="Exists('$(_PrebuiltDfuHelper)')" Text="[Bundle Firmware + DFU Helper] using prebuilt helper: $(_PrebuiltDfuHelper)" Importance="high" />
    <Copy Condition="Exists('$(_PrebuiltDfuHelper)')" SourceFiles="$(_PrebuiltDfuHelper)" DestinationFiles="$(OutDir)emwaver-dfu-helper.exe" SkipUnchangedFiles="false" />

    <!-- Local build (opt-in): run under VsDevCmd so link.exe can resolve MSVC libs across shells. -->
    <Message Condition="'$(BuildDfuHelper)' == 'true'" Text="[Bundle Firmware + DFU Helper] building helper via cargo (BuildDfuHelper=true)" Importance="high" />
    <Error Condition="'$(BuildDfuHelper)' == 'true' and '$(VsInstallRoot)' == ''" Text="VsInstallRoot not set; cannot locate VsDevCmd.bat for DFU helper build." />
    <Exec Condition="'$(BuildDfuHelper)' == 'true'" Command="cmd /c &quot;&quot;$(VsInstallRoot)\\Common7\\Tools\\VsDevCmd.bat&quot; -arch=x64 -host_arch=x64 &amp;&amp; cargo build --manifest-path &quot;$(_DfuHelperManifest)&quot; --release --target x86_64-pc-windows-msvc --target-dir &quot;$(_DfuHelperTarget)&quot;&quot;" />
    <Copy Condition="'$(BuildDfuHelper)' == 'true' and Exists('$(_DfuHelperExe)')" SourceFiles="$(_DfuHelperExe)" DestinationFiles="$(OutDir)emwaver-dfu-helper.exe" SkipUnchangedFiles="false" />

    <!-- Warn (don’t fail) if no helper is available; the UI will show a friendly error when attempting update. -->
    <Warning Condition="!Exists('$(OutDir)emwaver-dfu-helper.exe')" Text="DFU helper not bundled. Place a prebuilt helper at windows/EMWaver/Assets/dfu/emwaver-dfu-helper.exe or build with /p:BuildDfuHelper=true." />
  </Target>

  <!-- Sync bundled example scripts from repo assets into the Windows project folder.
       This makes the packaged path deterministic (Assets/DefaultScripts).
  -->
  <Target Name="SyncDefaultScripts" BeforeTargets="BeforeBuild">
    <ItemGroup>
      <_SrcDefaultScripts Include="..\\..\\assets\\default-scripts\\*.emw" />
      <_DestDefaultScripts Include="Assets\\DefaultScripts\\*.emw" />
    </ItemGroup>

    <MakeDir Directories="Assets\\DefaultScripts" />
    <Delete Files="@(_DestDefaultScripts)" />
    <Copy SourceFiles="@(_SrcDefaultScripts)" DestinationFolder="Assets\\DefaultScripts\\" SkipUnchangedFiles="false" />
  </Target>

  <ItemGroup>
    <!-- App icon asset (runtime). Keep as None (not PRI-indexed) but copy to output. -->
    <None Include="Assets\\emwaver.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromResourceIndexing>true</ExcludeFromResourceIndexing>
    </None>

    <!-- Ensure .gitkeep doesn't participate in PRI/resource indexing. -->
    <None Remove="Assets\\DefaultScripts\\.gitkeep" />

    <!-- Bundled (read-only) default scripts. Required in both unpackaged dev runs and packaged (MSIX/Store) builds. -->
    <Content Include="Assets\\DefaultScripts\\*.emw">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <!-- WinAppSDK PRI resource indexing can choke on arbitrary asset file types; treat .emw as plain content. -->
      <ExcludeFromResourceIndexing>true</ExcludeFromResourceIndexing>
    </Content>

    <!-- Bundled firmware payload (read-only). -->
    <Content Include="..\\..\\firmware\\emwaver.bin">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <TargetPath>emwaver.bin</TargetPath>
      <ExcludeFromResourceIndexing>true</ExcludeFromResourceIndexing>
    </Content>

    <!-- Bundled DFU helper. Built by BundleFirmwareAndDfuHelper target; included for publish as well. -->
    <Content Include="$(OutDir)emwaver-dfu-helper.exe" Condition="Exists('$(OutDir)emwaver-dfu-helper.exe')">
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <TargetPath>emwaver-dfu-helper.exe</TargetPath>
      <ExcludeFromResourceIndexing>true</ExcludeFromResourceIndexing>
    </Content>
  </ItemGroup>

</Project>
