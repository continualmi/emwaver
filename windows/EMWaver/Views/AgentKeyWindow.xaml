<Window
    x:Class="EMWaver.Views.AgentKeyWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Agent API Key"
    Width="440" Height="300"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Enter your MGPT API key to enable Agent replies."
                       FontSize="14" TextWrapping="Wrap" Margin="0,0,0,16" />
            <TextBlock Text="API Key" Margin="0,0,0,4" />
            <PasswordBox x:Name="ApiKeyPasswordBox" Height="30" />
            <TextBlock x:Name="StatusText" FontSize="12"
                       Foreground="{DynamicResource AppErrorTextBrush}"
                       Margin="0,8,0,0" Visibility="Collapsed" />
            <TextBlock FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       TextWrapping="Wrap" Margin="0,12,0,0">
                Your key is stored securely in Windows Credential Manager and never sent to EMWaver servers except when making Agent API requests.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="OnCancelClick" />
            <Button Content="Save" Width="80" IsDefault="True" Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
