<Window
    x:Class="EMWaver.Views.AgentKeyWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Agent API Key"
    Width="540" Height="440"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Agent API Key" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Add an MGPT API key to enable Agent replies. Local scripts and hardware control work without a key. Requests use the public MGPT endpoint /api/mgpt/responses."
                       FontSize="13" Foreground="{DynamicResource AppTextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,12" />
            <TextBlock Margin="0,0,0,16">
                <Hyperlink NavigateUri="https://mdl.continualmi.com/mgpt-api" Click="OnMgptLinkClick">
                    MGPT API Platform
                </Hyperlink>
            </TextBlock>

            <StackPanel x:Name="SavedKeyPanel" Visibility="Collapsed" Margin="0,0,0,16">
                <TextBlock Text="Saved key" FontWeight="SemiBold" Margin="0,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SavedKeyText" Grid.Column="0" IsReadOnly="True"
                             FontFamily="Consolas" Height="30" Margin="0,0,8,0" />
                    <Button x:Name="ViewSavedKeyButton" Grid.Column="1" Content="View" Width="62" Margin="0,0,8,0" Click="OnViewSavedKeyClick" />
                    <Button x:Name="CopySavedKeyButton" Grid.Column="2" Content="Copy" Width="62" Click="OnCopySavedKeyClick" />
                </Grid>
                <Button Content="Remove Saved Key" Width="130" Margin="0,10,0,0"
                        HorizontalAlignment="Left" Click="OnRemoveSavedKeyClick" />
            </StackPanel>

            <TextBlock x:Name="EnterKeyLabel" Text="Enter key" FontWeight="SemiBold" Margin="0,0,0,4" />
            <PasswordBox x:Name="ApiKeyPasswordBox" Height="30" />
            <TextBlock x:Name="StatusText" FontSize="12"
                       Foreground="{DynamicResource AppErrorTextBrush}"
                       Margin="0,8,0,0" Visibility="Collapsed" />
            <TextBlock FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,12,0,0">
                Your key is stored locally and is only sent when making Agent API requests.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Not Now" Width="80" Margin="0,0,8,0" Click="OnCancelClick" />
            <Button Content="Save Key" Width="90" IsDefault="True" Click="OnSaveClick" />
        </StackPanel>
    </Grid>
</Window>
