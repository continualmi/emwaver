<Window
    x:Class="EMWaver.Views.DeviceConnectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Device"
    Width="580" Height="540"
    MinWidth="480" MinHeight="440"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Status line -->
                <TextBlock x:Name="StatusLine" FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           Margin="0,0,0,16" />

                <!-- Device list card -->
                <Border Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Local devices" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" />
                        <TextBlock x:Name="NoDevicesText" Text="No EMWaver devices discovered yet."
                                   FontSize="13" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   Visibility="Visible" />
                        <ItemsControl x:Name="DeviceList" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Wi-Fi setup card (ESP only) -->
                <Border x:Name="WifiCard" Visibility="Collapsed"
                        Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Wi-Fi Setup" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                        <TextBlock Text="Provision this ESP32 for local network control."
                                   FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="SSID" FontSize="12" Grid.Row="0" Grid.Column="0" Margin="0,0,0,2" />
                            <TextBox x:Name="WifiSSIDBox" Grid.Row="1" Grid.Column="0" Height="28" />

                            <TextBlock Text="Password" FontSize="12" Grid.Row="0" Grid.Column="2" Margin="0,0,0,2" />
                            <PasswordBox x:Name="WifiPasswordBox" Grid.Row="1" Grid.Column="2" Height="28" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="WifiSendButton" Content="Send Wi-Fi Setup" Width="120"
                                    Margin="0,0,8,0" Click="OnWifiSendClick" />
                            <Button Content="Clear Setup" Width="90"
                                    Margin="0,0,8,0" Click="OnWifiClearClick" />
                            <Button Content="Status" Width="70" Click="OnWifiStatusClick" />
                        </StackPanel>

                        <TextBlock x:Name="WifiStatusText" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Firmware card -->
                <Border Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Firmware" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                            <TextBlock x:Name="FirmwareDescText" FontSize="12"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="FirmwareButton" Content="Update firmware"
                                Width="130" Height="32" VerticalAlignment="Center"
                                Click="OnFirmwareClick" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                BorderThickness="0,1,0,0" Padding="12,10">
            <StackPanel HorizontalAlignment="Right">
                <Button Content="Close" Width="80" Click="OnCloseClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
