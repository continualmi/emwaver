<UserControl
    x:Class="EMWaver.Views.ScriptsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="140" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="AgentPanelColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: script list -->
        <Border Grid.Column="0" Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Script list header -->
                <Border Grid.Row="0" Padding="10,8" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Scripts" FontWeight="SemiBold" FontSize="13" />
                </Border>

                <TextBox x:Name="ScriptSearchBox" Grid.Row="1"
                         Margin="8"
                         Height="28"
                         TextChanged="OnScriptSearchChanged"
                         ToolTip="Filter scripts"
                         Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                         Foreground="{DynamicResource EditorTextForegroundBrush}" />

                <!-- Script list items -->
                <ListBox x:Name="ScriptListBox" Grid.Row="2"
                         SelectionChanged="OnScriptSelected"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="10,10,8,2"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding FileName}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        Padding="7,2"
                                        Margin="6,0,0,0"
                                        CornerRadius="8"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ScriptPillCustomBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding KindLabel}" Value="Example">
                                                    <Setter Property="Background" Value="{DynamicResource ScriptPillExampleBackgroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding KindLabel}" Value="Library">
                                                    <Setter Property="Background" Value="{DynamicResource ScriptPillLibraryBackgroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding KindLabel}" Value="Kernel">
                                                    <Setter Property="Background" Value="{DynamicResource ScriptPillKernelBackgroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding KindLabel}" Value="Override">
                                                    <Setter Property="Background" Value="{DynamicResource ScriptPillOverrideBackgroundBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding KindLabel}"
                                               FontSize="9"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource ScriptPillCustomForegroundBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KindLabel}" Value="Example">
                                                        <Setter Property="Foreground" Value="{DynamicResource ScriptPillExampleForegroundBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KindLabel}" Value="Library">
                                                        <Setter Property="Foreground" Value="{DynamicResource ScriptPillLibraryForegroundBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KindLabel}" Value="Kernel">
                                                        <Setter Property="Foreground" Value="{DynamicResource ScriptPillKernelForegroundBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KindLabel}" Value="Override">
                                                        <Setter Property="Foreground" Value="{DynamicResource ScriptPillOverrideForegroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Grid splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- Center: editor + preview -->
        <Grid Grid.Column="2" Background="{DynamicResource EditorSurfaceBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Editor header -->
            <Border Grid.Row="0" Padding="10,6" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="EditorTitle" Text="No script selected" FontSize="12" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Find" Width="52" Height="24" Margin="8,0,0,0" Click="OnFindClick" />
                    <Button Grid.Column="2" Content="Go to Line" Width="76" Height="24" Margin="4,0,0,0" Click="OnGoToLineClick" />
                </Grid>
            </Border>

            <!-- Editor body (code) -->
            <avalon:TextEditor x:Name="EditorTextBox" Grid.Row="1"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               FontFamily="Consolas"
                               FontSize="13"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                               Foreground="{DynamicResource EditorTextForegroundBrush}"
                               TextChanged="OnEditorTextChanged"
                               Visibility="Visible" />

            <!-- Preview surface -->
            <ScrollViewer x:Name="PreviewScrollViewer" Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          Background="{DynamicResource PreviewSurfaceBackgroundBrush}"
                          Foreground="{DynamicResource AppTextForegroundBrush}"
                          Visibility="Collapsed">
                <ContentControl x:Name="PreviewContent" Margin="12"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" />
            </ScrollViewer>

            <!-- Error banner -->
            <Border x:Name="ErrorBanner" Grid.Row="2" Visibility="Collapsed"
                    Background="{DynamicResource StatusErrorBackgroundBrush}"
                    BorderBrush="{DynamicResource StatusErrorBorderBrush}"
                    BorderThickness="0,1,0,0" Padding="10,8">
                <TextBlock x:Name="ErrorText" FontSize="12"
                           Foreground="{DynamicResource AppErrorTextBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <Expander x:Name="TransportLogExpander" Grid.Row="3" Header="Transport log" IsExpanded="True"
                      BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                      BorderThickness="0,1,0,0">
                <Grid MaxHeight="160">
                    <TextBox x:Name="TransportLogTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="11"
                             Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                             Foreground="{DynamicResource EditorTextForegroundBrush}"
                             BorderThickness="0" />
                </Grid>
            </Expander>
        </Grid>

        <!-- Agent panel (right drawer) -->
        <Border x:Name="AgentPanel" Grid.Column="4" Background="{DynamicResource EditorSurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                BorderThickness="1,0,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Agent" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock x:Name="AgentEndpointText"
                                       Text="MGPT · /api/mgpt/responses"
                                       FontSize="10"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="AgentApiKeyButton" Width="86" Height="26" Click="OnAgentOpenKeyClick"
                                ToolTip="Agent API key">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="AgentApiKeyIcon" Text="🔒" FontSize="13" Margin="0,0,4,0" />
                                <TextBlock Text="API Key" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}" BorderThickness="0,0,0,1" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="AgentConversationBox"
                                  Grid.Column="0"
                                  Height="26"
                                  DisplayMemberPath="DisplayTitle"
                                  SelectionChanged="OnAgentConversationChanged" />
                        <Button Grid.Column="1" Content="New" Width="44" Height="26" Margin="6,0,0,0" Click="OnAgentNewChatClick" />
                        <Button Grid.Column="2" Content="Rename" Width="58" Height="26" Margin="4,0,0,0" Click="OnAgentRenameChatClick" />
                        <Button Grid.Column="3" Content="Delete" Width="50" Height="26" Margin="4,0,0,0" Click="OnAgentDeleteChatClick" />
                    </Grid>
                </Border>

                <Border x:Name="AgentSetupPanel" Grid.Row="2"
                        Background="{DynamicResource StatusWarningBackgroundBrush}"
                        BorderBrush="{DynamicResource StatusWarningBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8"
                        Visibility="Collapsed">
                    <TextBlock Text="Add an MGPT API key to enable Agent replies. Local scripts and hardware stay available without it."
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppTextForegroundBrush}" />
                </Border>

                <ScrollViewer x:Name="AgentMessagesScroll" Grid.Row="3"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="AgentMessagesPanel" Margin="8">
                        <UniformGrid x:Name="AgentSuggestionsPanel" Columns="2" Margin="0,0,0,8">
                            <Button Tag="How do I connect an EMWaver device over USB?" Click="OnAgentSuggestionClick" Margin="0,0,6,6" Padding="8">
                                <TextBlock Text="🔌 Connect over USB" TextWrapping="Wrap" />
                            </Button>
                            <Button Tag="Help me write a script for a connected board." Click="OnAgentSuggestionClick" Margin="0,0,0,6" Padding="8">
                                <TextBlock Text="💻 Script a board" TextWrapping="Wrap" />
                            </Button>
                            <Button Tag="Help me write a script to blink a GPIO pin." Click="OnAgentSuggestionClick" Margin="0,0,6,0" Padding="8">
                                <TextBlock Text="💡 Blink GPIO" TextWrapping="Wrap" />
                            </Button>
                            <Button Tag="How do I capture and replay an IR remote?" Click="OnAgentSuggestionClick" Margin="0,0,0,0" Padding="8">
                                <TextBlock Text="📡 IR capture/replay" TextWrapping="Wrap" />
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="4" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                        BorderThickness="0,1,0,0" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="AgentStatusText"
                                       Text="The Agent sees your message and the current script text."
                                       FontSize="10"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <Button x:Name="AgentStopButton" Grid.Column="1" Content="Stop" Width="48" Height="22"
                                    Visibility="Collapsed" Click="OnAgentStopClick" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AgentInputBox" Grid.Column="0" MinHeight="34" MaxHeight="96"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     KeyDown="OnAgentInputKeyDown" />
                            <Button x:Name="AgentSendButton" Grid.Column="1" Content="Send" Width="50" Height="28"
                                    Margin="4,0,0,0" Click="OnAgentSendClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
