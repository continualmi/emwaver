<Window
    x:Class="EMWaver.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="620" Height="640"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Script diagnostics section -->
            <GroupBox Header="Script diagnostics" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Control what local runtime details are shown while scripts run."
                               FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,8" />
                    <CheckBox Content="Show transport log in Scripts"
                              IsChecked="{Binding ShowTransportLog, Mode=TwoWay}" />
                </StackPanel>
            </GroupBox>

            <!-- Desktop MCP section -->
            <GroupBox Header="Desktop MCP" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox Content="Enable local MCP server"
                              IsChecked="{Binding McpServerEnabled, Mode=TwoWay}" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Margin="0,0,16,6" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding McpServerStatus}" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,6" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint" Margin="0,0,16,6" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding McpEndpointUrl}" IsReadOnly="True" Margin="0,0,0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Token" Margin="0,0,16,0" />
                        <DockPanel Grid.Row="2" Grid.Column="1">
                            <Button Content="Reset" Width="70" DockPanel.Dock="Right" Margin="8,0,0,0" Click="OnResetMcpTokenClick" />
                            <TextBox Text="{Binding McpServerToken}" IsReadOnly="True" />
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- App updates section -->
            <GroupBox Header="App updates" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Check for desktop app updates. Local scripts and device access do not require an account."
                               FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Button Content="Check for Updates…" Width="150" HorizontalAlignment="Left" Click="OnCheckForUpdatesClick" />
                </StackPanel>
            </GroupBox>

            <!-- App information section -->
            <GroupBox Header="App" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Margin="0,0,16,4" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Commit" Margin="0,0,16,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppCommit}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                </Grid>
            </GroupBox>

        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Done" Width="80" IsDefault="True" Click="OnDoneClick" />
        </StackPanel>
    </Grid>
</Window>
