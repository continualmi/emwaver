<Window
    x:Class="EMWaver.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:EMWaver.Converters"
    Title="Settings"
    Width="560" Height="560"
    WindowStartupLocation="CenterOwner"
    WindowStyle="ToolWindow"
    ResizeMode="NoResize">

    <Window.Resources>
        <converters:ThemeToIndexConverter x:Key="ThemeToIndexConverter" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Agent section -->
            <GroupBox Header="Agent" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Add an MGPT API key to enable Agent replies. Local scripts and hardware control work without a key."
                               FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://mdl.continualmi.com/mgpt-api" Click="OnMgptLinkClick">
                            MGPT API Platform
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <!-- Device access section -->
            <GroupBox Header="Device access" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Local scripts and hardware control work immediately."
                               FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,8" />
                    <CheckBox Content="Show transport log in Scripts"
                              IsChecked="{Binding ShowTransportLog, Mode=TwoWay}" />
                </StackPanel>
            </GroupBox>

            <!-- Device diagnostics section -->
            <GroupBox Header="Device diagnostics" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox Content="Log transport packets on ESP serial"
                              IsChecked="{Binding TransportDebugLoggingEnabled, Mode=TwoWay}" />
                    <TextBlock Text="When enabled, ESP32 firmware logs BLE, USB, and Wi-Fi command packets on the serial monitor."
                               FontSize="12" Foreground="{DynamicResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </GroupBox>

            <!-- Theme section -->
            <GroupBox Header="Appearance" Padding="12">
                <StackPanel>
                    <TextBlock Text="Theme" Margin="0,0,0,4" />
                    <ComboBox SelectedIndex="{Binding Theme, Converter={StaticResource ThemeToIndexConverter}}" Width="200" HorizontalAlignment="Left">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Done" Width="80" IsDefault="True" Click="OnDoneClick" />
        </StackPanel>
    </Grid>
</Window>
