<Application
    x:Class="EMWaver.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="EditorSurfaceBackgroundBrush" Color="#FFF7F8FA" />
                    <SolidColorBrush x:Key="EditorSurfaceBorderBrush" Color="#FFD8DEE4" />
                    <SolidColorBrush x:Key="EditorTextForegroundBrush" Color="#FF1F2328" />
                    <SolidColorBrush x:Key="PreviewSurfaceBackgroundBrush" Color="#FFFBFCFD" />
                    <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#FFD8DEE4" />
                    <SolidColorBrush x:Key="GeneratedSurfaceBackgroundBrush" Color="#FFF7F8FA" />
                    <SolidColorBrush x:Key="GeneratedSurfaceBorderBrush" Color="#FFD8DEE4" />
                    <SolidColorBrush x:Key="GeneratedDividerBrush" Color="#FFD8DEE4" />
                    <SolidColorBrush x:Key="PlotLineBrush" Color="#FF005FB8" />
                    <SolidColorBrush x:Key="ReadOnlyBannerBackgroundBrush" Color="#FFF3F4F6" />
                    <SolidColorBrush x:Key="ReadOnlyBannerBorderBrush" Color="#FFD0D7DE" />
                    <SolidColorBrush x:Key="AgentUserBubbleBrush" Color="#1F0078D4" />
                    <SolidColorBrush x:Key="AgentAssistantBubbleBrush" Color="#14808080" />
                    <SolidColorBrush x:Key="AgentToolBubbleBrush" Color="#198C8C8C" />
                    <SolidColorBrush x:Key="AgentBubbleBorderBrush" Color="#1E6B7280" />
                    <SolidColorBrush x:Key="AppErrorTextBrush" Color="#FFB42318" />
                    <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#FFFFF4CE" />
                    <SolidColorBrush x:Key="StatusWarningBorderBrush" Color="#FFE5C365" />
                    <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#FFFDECEC" />
                    <SolidColorBrush x:Key="StatusErrorBorderBrush" Color="#FFF2B8B5" />
                    <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#FFE8F5E9" />
                    <SolidColorBrush x:Key="StatusSuccessBorderBrush" Color="#FFA5D6A7" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="EditorSurfaceBackgroundBrush" Color="#FF1E1E1E" />
                    <SolidColorBrush x:Key="EditorSurfaceBorderBrush" Color="#FF3A3A3A" />
                    <SolidColorBrush x:Key="EditorTextForegroundBrush" Color="#FFD4D4D4" />
                    <SolidColorBrush x:Key="PreviewSurfaceBackgroundBrush" Color="#FF1E1E1E" />
                    <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#FF3A3A3A" />
                    <SolidColorBrush x:Key="GeneratedSurfaceBackgroundBrush" Color="#FF1E1E1E" />
                    <SolidColorBrush x:Key="GeneratedSurfaceBorderBrush" Color="#FF3A3A3A" />
                    <SolidColorBrush x:Key="GeneratedDividerBrush" Color="#40FFFFFF" />
                    <SolidColorBrush x:Key="PlotLineBrush" Color="#FF80C8FF" />
                    <SolidColorBrush x:Key="ReadOnlyBannerBackgroundBrush" Color="#FF242424" />
                    <SolidColorBrush x:Key="ReadOnlyBannerBorderBrush" Color="#FF3A3A3A" />
                    <SolidColorBrush x:Key="AgentUserBubbleBrush" Color="#240078D4" />
                    <SolidColorBrush x:Key="AgentAssistantBubbleBrush" Color="#12808080" />
                    <SolidColorBrush x:Key="AgentToolBubbleBrush" Color="#198C8C8C" />
                    <SolidColorBrush x:Key="AgentBubbleBorderBrush" Color="#24505050" />
                    <SolidColorBrush x:Key="AppErrorTextBrush" Color="#FFFFB4AB" />
                    <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#FF332A1A" />
                    <SolidColorBrush x:Key="StatusWarningBorderBrush" Color="#FF6D5830" />
                    <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#FF3A1E1E" />
                    <SolidColorBrush x:Key="StatusErrorBorderBrush" Color="#FF7A3737" />
                    <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#FF173222" />
                    <SolidColorBrush x:Key="StatusSuccessBorderBrush" Color="#FF2E6E47" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
