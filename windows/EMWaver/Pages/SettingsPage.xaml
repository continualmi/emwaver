<Page
    x:Class="EMWaver.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" />

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Account" FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Status:" />
                        <TextBlock x:Name="AuthStatusText" Text="Signed out" />
                    </StackPanel>

                    <TextBlock x:Name="AuthDetailText" Text="" Opacity="0.75" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SignInButton" Content="Sign in" Click="OnSignInClick" />
                        <Button x:Name="SignOutButton" Content="Sign out" Click="OnSignOutClick" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Editor" FontWeight="SemiBold" />

                    <ComboBox x:Name="EditorModeCombo" SelectionChanged="OnEditorModeChanged" Width="260">
                        <ComboBoxItem Content="Simple" Tag="simple" />
                        <ComboBoxItem Content="Code (JS)" Tag="code" />
                    </ComboBox>

                    <TextBlock Text="Code editor is native (RichEdit document formatting) and uses JS-focused tokenization." Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Cloud" FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Backend:" />
                        <TextBlock x:Name="BackendUrlText" Text="" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Mode:" />
                        <ComboBox x:Name="BackendModeCombo" SelectionChanged="OnBackendModeChanged" Width="220">
                            <ComboBoxItem Content="Azure (prod)" Tag="prod" />
                            <ComboBoxItem Content="Local" Tag="local" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Local URL:" />
                        <TextBox x:Name="LocalBackendUrlBox" Width="320" TextChanged="OnLocalBackendUrlChanged" />
                    </StackPanel>

                    <TextBlock Text="Changing backend will sign you out and restart cloud services." Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
