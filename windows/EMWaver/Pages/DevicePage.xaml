<Page
    x:Class="EMWaver.Pages.DevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver.Pages">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Device" FontSize="20" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,12">
            <Button Content="Refresh Ports" Click="OnRefreshClick" />
            <ToggleSwitch x:Name="AutoConnectSwitch" Header="Auto-connect" Toggled="OnAutoConnectToggled" />
            <Button Content="Disconnect" Click="OnDisconnectClick" />
            <Button Content="Enter Update Mode" Click="OnEnterUpdateModeClick" />
            <Button Content="Refresh Update Mode" Click="OnRefreshUpdateModeClick" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="10">
                <TextBlock Text="Ports" FontWeight="SemiBold" />
                <ListView x:Name="PortsList" SelectionMode="Single" Height="320" />
                <Button Content="Connect" Click="OnConnectClick" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="10" Margin="16,0,0,0">
                <TextBlock Text="Status" FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText" Text="Disconnected" />
                <TextBlock x:Name="VersionText" Foreground="Gray" />
                <TextBlock x:Name="SecureText" Foreground="Gray" />
                <TextBlock x:Name="DeviceIdText" Foreground="Gray" TextWrapping="Wrap" />
                <TextBlock x:Name="DfuText" Foreground="Gray" />
                <TextBlock x:Name="ErrorText" Foreground="DarkRed" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
