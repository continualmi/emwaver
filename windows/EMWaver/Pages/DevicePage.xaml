<Page
    x:Class="EMWaver.Pages.DevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
            <Button Content="Refresh Ports" Click="OnRefreshClick" />
            <ToggleSwitch x:Name="AutoConnectSwitch" Header="Auto-connect" Toggled="OnAutoConnectToggled" />
            <Button x:Name="DisconnectButton" Content="Disconnect" Click="OnDisconnectClick" />
            <Button x:Name="UpdateModeButton" Content="Enter Update Mode" Click="OnEnterUpdateModeClick" />
            <Button Content="Refresh Update Mode" Click="OnRefreshUpdateModeClick" />
            <Button x:Name="PrimaryFirmwareButton" Content="Update firmware" Click="OnPrimaryFirmwareClick" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="14">
            <Border CornerRadius="12" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Ports" FontSize="16" FontWeight="SemiBold" />
                    <ListView x:Name="PortsList" SelectionMode="Single" Height="220" />
                    <Button Content="Connect" Click="OnConnectClick" />
                </StackPanel>
            </Border>

            <Border CornerRadius="12" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="My devices" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="DevicesIntroText" Text="Optional account cache and recently seen EMWaver devices." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ListView x:Name="DevicesList" Height="220">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Padding="0,4">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">
                                        <Run Text="{Binding BoardType}" />
                                        <Run Text="  UID " />
                                        <Run Text="{Binding HardwareUid}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="14">
            <Border CornerRadius="12" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText" Text="Disconnected" />
                    <TextBlock x:Name="VersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="BoardTypeText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="HardwareUidText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SecureText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="DeviceIdText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="AttachStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="ClaimStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="OfflineStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="UpdateModeStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="VerificationText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="ErrorText" Foreground="{ThemeResource AppErrorTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border CornerRadius="12" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Firmware" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="FirmwareStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <ProgressBar x:Name="FirmwareProgressBar" Minimum="0" Maximum="100" Value="0" />
                    <TextBlock x:Name="FirmwareProgressText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBox x:Name="ActivityLogTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
