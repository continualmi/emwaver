<Page
    x:Class="EMWaver.Pages.HostsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Hosts" FontSize="20" FontWeight="SemiBold" />
                <Button Content="Refresh" Click="OnRefreshClick" />
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="" Opacity="0.75" TextWrapping="Wrap" />

            <ListView x:Name="HostsList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding OnlineColor}" />
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding UsbLabel}" Opacity="0.75" />
                                </StackPanel>

                                <TextBlock Text="{Binding Subtitle}" Opacity="0.75" />
                                <TextBlock Text="{Binding PortLine}" Opacity="0.75" />
                                <TextBlock Text="{Binding ScriptLine}" Opacity="0.75" />
                                <TextBlock Text="{Binding IdLine}" Opacity="0.60" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
