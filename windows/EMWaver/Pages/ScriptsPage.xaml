<Page
    x:Class="EMWaver.Pages.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:EMWaver.Converters"
    xmlns:local="using:EMWaver.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="AgentColumn" Width="0" />
            </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <ListView x:Name="ScriptsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <SymbolIcon
                                        Grid.Column="0"
                                        Symbol="View"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Visibility="{Binding IsBundled, Converter={StaticResource BoolToVisibility}}" />

                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="2">
                        <TextBlock x:Name="EditorTitleText" Text="Select a script" FontWeight="SemiBold" />
                        <TextBlock x:Name="EditorSubtitleText" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <Grid Grid.Row="1" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                            <RadioButton x:Name="PreviewModeButton" Content="Preview" GroupName="ScriptViewMode" IsChecked="True" Checked="OnViewModeChanged" />
                            <RadioButton x:Name="EditModeButton" Content="Edit" GroupName="ScriptViewMode" Checked="OnViewModeChanged" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid x:Name="EditorPane" Visibility="Collapsed">
                                <Grid
                                    x:Name="EditorHost"
                                    Visibility="Collapsed"
                                    Loaded="OnEditorHostLoaded"
                                    Unloaded="OnEditorHostUnloaded"
                                    LayoutUpdated="OnEditorHostLayoutUpdated"
                                    SizeChanged="OnEditorHostSizeChanged"
                                    PointerPressed="OnEditorHostPointerPressed">
                                    <!-- Native Scintilla editor is hosted as an owned HWND positioned over this panel. -->
                                    <Border Background="#1E1E1E" CornerRadius="6" />
                                </Grid>

                                <TextBlock
                                    x:Name="EmptyHint"
                                    Text="Pick a script to view/edit."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />
                            </Grid>

                            <Grid x:Name="PreviewPane" Visibility="Visible">
                                <ScrollViewer>
                                    <StackPanel x:Name="PreviewHost" />
                                </ScrollViewer>

                                <TextBlock
                                    x:Name="PreviewHint"
                                    Text="Select a script to preview its UI."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2" Margin="12,0,0,0">
                <Border
                    x:Name="AgentPane"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="Collapsed">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Agent" FontWeight="SemiBold" />

                        <ListView Grid.Row="1" x:Name="AgentMessagesList" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AgentInput" PlaceholderText="Ask the agent..." />
                            <Button Grid.Column="1" Content="Send" Click="OnAgentSendClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
