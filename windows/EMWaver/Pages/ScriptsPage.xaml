<Page
    x:Class="EMWaver.Pages.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:EMWaver.Converters"
    xmlns:local="using:EMWaver.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:ScriptListItemTemplateSelector x:Key="ScriptListTemplateSelector" />
        <DataTemplate x:Key="AgentMessageTemplate">
            <Grid>
                <Border
                    MaxWidth="520"
                    CornerRadius="10"
                    Padding="10"
                    HorizontalAlignment="{Binding BubbleAlignment}"
                    Background="{Binding BubbleBackground}"
                    BorderBrush="{Binding BubbleBorderBrush}"
                    BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="{Binding IconGlyph}" FontSize="12" Opacity="0.8" />
                            <TextBlock Text="{Binding RoleLabel}" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                        <TextBlock
                            Text="{Binding RenderedText}"
                            TextWrapping="Wrap"
                            IsTextSelectionEnabled="True" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="AgentColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Scripts list -->
            <Border Grid.Column="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView x:Name="ScriptsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged" RightTapped="OnScriptsListRightTapped">
                    <ListView.Resources>
                        <DataTemplate x:Key="ScriptItemTemplate">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontWeight="SemiBold" />

                                <SymbolIcon
                                    Grid.Column="1"
                                    Symbol="View"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsBundled, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </DataTemplate>

                        <DataTemplate x:Key="SignalItemTemplate">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="signal" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>

                        <DataTemplate x:Key="ScriptSessionTemplate">
                            <Grid ColumnSpacing="8" Padding="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;" FontSize="11" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    MinWidth="32"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Click="OnSessionStopClick"
                                    ToolTipService.ToolTip="Stop script">
                                    <FontIcon Glyph="&#xE71A;" FontSize="12" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.Resources>

                    <ListView.ItemTemplateSelector>
                        <conv:ScriptListItemTemplateSelector
                            ScriptTemplate="{StaticResource ScriptItemTemplate}"
                            SignalTemplate="{StaticResource SignalItemTemplate}"
                            SessionTemplate="{StaticResource ScriptSessionTemplate}" />
                    </ListView.ItemTemplateSelector>

                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" Margin="6,12,6,6" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ContextFlyout>
                        <MenuFlyout Opening="OnScriptsListContextOpening">
                            <MenuFlyoutItem x:Name="ScriptsContextRenameItem" Text="Rename" Click="OnScriptsContextRenameClick" />
                            <MenuFlyoutItem x:Name="ScriptsContextDeleteItem" Text="Delete" Click="OnScriptsContextDeleteClick" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                </ListView>
            </Border>

            <!-- Editor/Preview region (toggles; not shown simultaneously) -->
            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <!-- EDITOR PANE (default) -->
                    <Grid x:Name="EditorPane" Visibility="Visible" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Read-only hint for bundled scripts -->
                        <Border
                            x:Name="ReadOnlyBanner"
                            Grid.Row="0"
                            CornerRadius="6"
                            Background="{ThemeResource ReadOnlyBannerBackgroundBrush}"
                            BorderBrush="{ThemeResource ReadOnlyBannerBorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="Bundled script (read-only). Make a copy to edit."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center" />
                                <Button
                                    Grid.Column="1"
                                    Content="Make a copy"
                                    Click="OnMakeCopyBannerClick" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <!-- Simple editor (Windows uses a single editor now; no variants/JS modes). -->
                            <TextBox
                                x:Name="EditorBox"
                                BorderThickness="0"
                                Background="{ThemeResource EditorSurfaceBackgroundBrush}"
                                Foreground="{ThemeResource EditorTextForegroundBrush}"
                                FontFamily="Consolas"
                                FontSize="13"
                                TextWrapping="NoWrap"
                                AcceptsReturn="True"
                                IsSpellCheckEnabled="False"
                                IsTextPredictionEnabled="False"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                TextChanged="OnEditorTextChanged" />

                            <TextBlock
                                x:Name="EmptyHint"
                                Text="Pick a script to view/edit."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <!-- PREVIEW PANE -->
                    <Grid x:Name="PreviewPane" Visibility="Collapsed">
                        <Border CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource PreviewSurfaceBorderBrush}"
                                Background="{ThemeResource PreviewSurfaceBackgroundBrush}"
                                Padding="10">
                            <Grid>
                                <ScrollViewer>
                                    <StackPanel x:Name="PreviewHost" />
                                </ScrollViewer>

                                <TextBlock
                                    x:Name="PreviewHint"
                                    Text="Run the script to render its UI."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="AgentPaneSplitter"
                    Grid.Column="2"
                    Width="6"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource ControlStrokeColorDefaultBrush}"
                    Opacity="0.35"
                    Visibility="Collapsed"
                    PointerEntered="OnAgentSplitterPointerEntered"
                    PointerExited="OnAgentSplitterPointerExited"
                    PointerPressed="OnAgentSplitterPointerPressed"
                    PointerMoved="OnAgentSplitterPointerMoved"
                    PointerReleased="OnAgentSplitterPointerReleased"
                    PointerCanceled="OnAgentSplitterPointerReleased" />

            <!-- ELM pane -->
            <Grid Grid.Column="3" Margin="12,0,0,0">
                <Border
                    x:Name="AgentPane"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="Collapsed">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical" Spacing="8">
                            <Grid ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE945;" /><TextBlock Text="ELM" FontWeight="SemiBold" /></StackPanel>

                                <Button Grid.Column="1" Padding="2" MinWidth="22" Height="22" VerticalAlignment="Center" ToolTipService.ToolTip="What is ELM?">
                                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <StackPanel Spacing="8" MaxWidth="280" Padding="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE945;" /><TextBlock Text="ELM" FontWeight="SemiBold" /></StackPanel>
                                                <TextBlock Text="Electronics Language Model" Opacity="0.8" />
                                                <TextBlock Text="An AI language model trained to control EMWaver and help with electronics workflows."
                                                           TextWrapping="Wrap"
                                                           Opacity="0.8" />
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>

                                <ComboBox Grid.Column="2" x:Name="AgentConversationsCombo" MinWidth="140" DisplayMemberPath="DisplayTitle" SelectionChanged="OnAgentConversationChanged" />

                                <Button Grid.Column="3" Padding="8,2" MinWidth="30" Height="30" ToolTipService.ToolTip="Conversation actions">
                                    <FontIcon Glyph="&#xE10C;" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="New" Click="OnAgentNewChatClick" />
                                            <MenuFlyoutItem Text="Clear" Click="OnAgentClearClick" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <TextBlock x:Name="AgentStatusText" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                            <Border x:Name="AgentSignInNotice"
                                    Visibility="Collapsed"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="Configure an Agent API key to enable Agent replies. Local scripts and hardware control remain available."
                                               TextWrapping="Wrap"
                                               Opacity="0.85"
                                               VerticalAlignment="Center" />
                                    <Button Content="Configure…" Visibility="Collapsed" Click="OnAgentSignInClick" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="AgentKeyNotice"
                                    Visibility="Collapsed"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE72E;" Opacity="0.8"/>
                                    <TextBlock Text="Configure an Agent API key to enable Agent replies."
                                               TextWrapping="Wrap"
                                               Opacity="0.85"
                                               VerticalAlignment="Center" />
                                    <Button Content="Configure Agent…" Visibility="Collapsed" Click="OnConfigureAgentKeyClick" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="1" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" x:Name="AgentThinkingRow" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                                <ProgressRing Width="14" Height="14" IsActive="True" />
                                <TextBlock Text="Thinking…" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ListView Grid.Row="1"
                                      x:Name="AgentMessagesList"
                                      ItemTemplate="{StaticResource AgentMessageTemplate}"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollMode="Enabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AgentInput" PlaceholderText="Message" TextChanged="OnAgentInputTextChanged" />
                            <Button x:Name="AgentSendButton" Grid.Column="1" Content="Send" Click="OnAgentSendClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
