<Page
    x:Class="EMWaver.Pages.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver.Pages">

    <Grid Padding="16" RowSpacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton x:Name="NewButton" Label="New" Icon="Add" Click="OnNewClick" />
            <AppBarButton x:Name="RunButton" Label="Run" Icon="Play" Click="OnRunClick" IsEnabled="False" />
            <AppBarButton x:Name="SaveButton" Label="Save" Icon="Save" Click="OnSaveClick" IsEnabled="False" />
            <AppBarToggleButton x:Name="AgentToggleButton" Label="Agent" IsChecked="False" Click="OnAgentToggleClick">
                <AppBarToggleButton.Icon>
                    <SymbolIcon Symbol="Message" />
                </AppBarToggleButton.Icon>
            </AppBarToggleButton>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="MakeCopyButton" Label="Make Copy" Click="OnMakeCopyClick" IsEnabled="False" />
                <AppBarButton x:Name="RenameButton" Label="Rename" Click="OnRenameClick" IsEnabled="False" />
                <AppBarButton x:Name="DeleteButton" Label="Delete" Click="OnDeleteClick" IsEnabled="False" />
                <AppBarButton Label="Refresh" Click="OnRefreshClick" />
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="AgentColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView x:Name="ScriptsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding KindLabel}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="2">
                        <TextBlock x:Name="EditorTitleText" Text="Select a script" FontWeight="SemiBold" />
                        <TextBlock x:Name="EditorSubtitleText" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid x:Name="EditorHost" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="0,0,1,0"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="6,0,0,6"
                                Padding="8,10,8,10">
                                <ScrollViewer
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Disabled"
                                    IsHitTestVisible="False">
                                    <TextBlock
                                        x:Name="LineNumbersText"
                                        FontFamily="Consolas"
                                        FontSize="13"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextAlignment="Right">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LineNumbersTransform" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Column="1">
                                <RichEditBox
                                    x:Name="EditorBox"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                    SelectionHighlightColor="{ThemeResource SystemAccentColor}"
                                    TextWrapping="NoWrap"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    IsSpellCheckEnabled="False"
                                    Padding="10,10,10,10" />
                            </Grid>
                        </Grid>

                        <TextBlock
                            x:Name="EmptyHint"
                            Text="Pick a script to view/edit."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2" Margin="12,0,0,0">
                <Border
                    x:Name="AgentPane"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="Collapsed">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Agent" FontWeight="SemiBold" />

                        <ListView Grid.Row="1" x:Name="AgentMessagesList" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AgentInput" PlaceholderText="Ask the agent..." />
                            <Button Grid.Column="1" Content="Send" Click="OnAgentSendClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
