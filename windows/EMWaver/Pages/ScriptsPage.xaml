<Page
    x:Class="EMWaver.Pages.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:EMWaver.Converters"
    xmlns:local="using:EMWaver.Pages"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:ScriptListItemTemplateSelector x:Key="ScriptListTemplateSelector" />
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="AgentColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Scripts list -->
            <Border Grid.Column="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView x:Name="ScriptsList" SelectionMode="Single" SelectionChanged="OnSelectionChanged">
                    <ListView.Resources>
                        <DataTemplate x:Key="ScriptItemTemplate">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontWeight="SemiBold" />

                                <SymbolIcon
                                    Grid.Column="1"
                                    Symbol="View"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsBundled, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </DataTemplate>

                        <DataTemplate x:Key="SignalItemTemplate">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding FileName}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="signal" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.Resources>

                    <ListView.ItemTemplateSelector>
                        <conv:ScriptListItemTemplateSelector
                            ScriptTemplate="{StaticResource ScriptItemTemplate}"
                            SignalTemplate="{StaticResource SignalItemTemplate}" />
                    </ListView.ItemTemplateSelector>

                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" Margin="6,12,6,6" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                </ListView>
            </Border>

            <!-- Editor/Preview region (toggles; not shown simultaneously) -->
            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <!-- EDITOR PANE (default) -->
                    <Grid x:Name="EditorPane" Visibility="Visible" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Read-only hint for bundled scripts -->
                        <Border
                            x:Name="ReadOnlyBanner"
                            Grid.Row="0"
                            CornerRadius="6"
                            Background="#242424"
                            BorderBrush="#3A3A3A"
                            BorderThickness="1"
                            Padding="10"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="Bundled script (read-only). Make a copy to edit."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center" />
                                <Button
                                    Grid.Column="1"
                                    Content="Make a copy"
                                    Click="OnMakeCopyBannerClick" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <!-- Simple editor (fallback) -->
                            <TextBox
                                x:Name="EditorBox"
                                BorderThickness="0"
                                Background="#1E1E1E"
                                Foreground="#D4D4D4"
                                FontFamily="Consolas"
                                FontSize="13"
                                TextWrapping="NoWrap"
                                AcceptsReturn="True"
                                IsSpellCheckEnabled="False"
                                IsTextPredictionEnabled="False"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                TextChanged="OnEditorTextChanged" />

                            <!-- Highlighted editor (RichEditBox) -->
                            <RichEditBox
                                x:Name="RichEditor"
                                Visibility="Collapsed"
                                BorderThickness="0"
                                Background="#1E1E1E"
                                Foreground="#D4D4D4"
                                FontFamily="Consolas"
                                FontSize="13"
                                IsSpellCheckEnabled="False"
                                IsTextPredictionEnabled="False"
                                TextChanged="OnRichEditorTextChanged" />

                            <!-- -->

                            <TextBlock
                                x:Name="EmptyHint"
                                Text="Pick a script to view/edit."
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <!-- PREVIEW PANE -->
                    <Grid x:Name="PreviewPane" Visibility="Collapsed">
                        <Border CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" Background="#1E1E1E" Padding="10">
                            <Grid>
                                <ScrollViewer>
                                    <StackPanel x:Name="PreviewHost" />
                                </ScrollViewer>

                                <TextBlock
                                    x:Name="PreviewHint"
                                    Text="Run the script to render its UI."
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Agent pane -->
            <Grid Grid.Column="2" Margin="12,0,0,0">
                <Border
                    x:Name="AgentPane"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="Collapsed">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Agent" FontWeight="SemiBold" />

                        <ListView Grid.Row="1" x:Name="AgentMessagesList" />

                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AgentInput" PlaceholderText="Ask the agent..." />
                            <Button Grid.Column="1" Content="Send" Click="OnAgentSendClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
