<ContentDialog
    x:Class="EMWaver.Dialogs.AccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Agent API Key"
    CloseButtonText="Close"
    DefaultButton="Close"
    MinWidth="560">

    <StackPanel Spacing="14">
        <StackPanel Spacing="6">
            <TextBlock Text="Agent API key" FontSize="22" FontWeight="SemiBold" />
            <TextBlock
                x:Name="AuthDetailText"
                Text="Enter an Agent API key to enable Agent replies. Local scripts and hardware control do not require a key."
                Opacity="0.75"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="API key" FontWeight="SemiBold" />
            <PasswordBox
                x:Name="ApiKeyBox"
                PlaceholderText="emw_sk_..."
                PasswordRevealMode="Peek" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="Status:" />
            <TextBlock x:Name="AuthStatusText" Text="No key saved" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="ManageOnWebButton" Content="Manage Key" Visibility="Collapsed" Click="OnManageOnWebClick" />
            <Button x:Name="SaveButton" Content="Save Key" Click="OnSaveKeyClick" />
            <Button x:Name="SignOutButton" Content="Remove Key" Click="OnSignOutClick" Visibility="Collapsed" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
