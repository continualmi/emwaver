<ContentDialog
    x:Class="EMWaver.Dialogs.AccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Account"
    CloseButtonText="Close"
    DefaultButton="Close"
    MinWidth="560">

    <StackPanel Spacing="14">
        <StackPanel Spacing="6">
            <TextBlock Text="EMWaver API key" FontSize="22" FontWeight="SemiBold" />
            <TextBlock
                x:Name="AuthDetailText"
                Text="Create or replace your EMWaver API key on the web, then paste it here."
                Opacity="0.75"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="API key" FontWeight="SemiBold" />
            <PasswordBox
                x:Name="ApiKeyBox"
                PlaceholderText="emw_sk_..."
                PasswordRevealMode="Peek" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="Status:" />
            <TextBlock x:Name="AuthStatusText" Text="Signed out" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="ManageOnWebButton" Content="Manage on Web" Click="OnManageOnWebClick" />
            <Button x:Name="SaveButton" Content="Save Key" Click="OnSaveKeyClick" />
            <Button x:Name="SignOutButton" Content="Sign out" Click="OnSignOutClick" Visibility="Collapsed" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
