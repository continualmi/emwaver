<ContentDialog
    x:Class="EMWaver.Dialogs.FirmwareUpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Device Setup"
    PrimaryButtonText="Update device"
    CloseButtonText="Close"
    DefaultButton="Primary">

    <ScrollViewer>
        <StackPanel Spacing="14" Padding="6">
            <Border CornerRadius="10" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="SummaryTitleText" Text="Device" FontWeight="SemiBold" />
                    <TextBlock x:Name="SummaryText" Text="Preparing device state..." TextWrapping="Wrap" />
                    <TextBlock x:Name="BoardInfoText" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="ClaimStatusText" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="BootloaderStatusText" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SignInStatusText" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="RefreshStateButton" Content="Refresh" Click="OnRefreshStateClick" />
                <Button x:Name="VerifyRunModeButton" Content="Verify Run Mode" Click="OnVerifyRunModeClick" />
                <Button x:Name="VerifyUpdateModeButton" Content="Verify Update Mode" Click="OnVerifyUpdateModeClick" />
                <Button x:Name="OpenAccountButton" Content="Open account" Click="OnOpenAccountClick" />
            </StackPanel>

            <Border x:Name="ErrorPanel"
                    CornerRadius="10"
                    Padding="12"
                    Background="{ThemeResource StatusErrorBackgroundBrush}"
                    BorderBrush="{ThemeResource StatusErrorBorderBrush}"
                    BorderThickness="1">
                <TextBlock x:Name="ErrorText" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
            </Border>

            <StackPanel x:Name="ProgressPanel" Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressMessageText" Grid.Column="0" Text="Updating..." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ProgressPctText" Grid.Column="1" Text="0%" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
                <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" />
                <TextBlock x:Name="VerificationText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <Border x:Name="DonePanel"
                    CornerRadius="10"
                    Padding="12"
                    Background="{ThemeResource StatusSuccessBackgroundBrush}"
                    BorderBrush="{ThemeResource StatusSuccessBorderBrush}"
                    BorderThickness="1">
                <TextBlock x:Name="DoneText" Text="Update complete. Reconnect the device to use it." Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="Activity log" FontWeight="SemiBold" />
            <TextBox x:Name="ActivityLogTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
