<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App-wide contrast -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="AppTextForegroundBrush" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#FFB8C0CC" />
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>

    <!-- Editor surfaces -->
    <SolidColorBrush x:Key="EditorSurfaceBackgroundBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="EditorSurfaceBorderBrush" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="EditorTextForegroundBrush" Color="#FFD4D4D4" />

    <!-- Preview surfaces -->
    <SolidColorBrush x:Key="PreviewSurfaceBackgroundBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#FF3A3A3A" />

    <!-- Generated content surfaces -->
    <SolidColorBrush x:Key="GeneratedSurfaceBackgroundBrush" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="GeneratedSurfaceBorderBrush" Color="#FF3A3A3A" />
    <SolidColorBrush x:Key="GeneratedDividerBrush" Color="#40FFFFFF" />

    <!-- Plot -->
    <SolidColorBrush x:Key="PlotLineBrush" Color="#FF80C8FF" />

    <!-- Script list pills / read-only banner -->
    <SolidColorBrush x:Key="ScriptPillExampleBackgroundBrush" Color="#FF102A43" />
    <SolidColorBrush x:Key="ScriptPillExampleForegroundBrush" Color="#FFB9DCFF" />
    <SolidColorBrush x:Key="ScriptPillLibraryBackgroundBrush" Color="#FF2A173A" />
    <SolidColorBrush x:Key="ScriptPillLibraryForegroundBrush" Color="#FFE1C6FF" />
    <SolidColorBrush x:Key="ScriptPillKernelBackgroundBrush" Color="#FF3A2C10" />
    <SolidColorBrush x:Key="ScriptPillKernelForegroundBrush" Color="#FFFFD782" />
    <SolidColorBrush x:Key="ScriptPillCustomBackgroundBrush" Color="#FF173222" />
    <SolidColorBrush x:Key="ScriptPillCustomForegroundBrush" Color="#FFB7E4C7" />
    <SolidColorBrush x:Key="ScriptPillOverrideBackgroundBrush" Color="#FF3A1E1E" />
    <SolidColorBrush x:Key="ScriptPillOverrideForegroundBrush" Color="#FFFFB4AB" />
    <SolidColorBrush x:Key="ReadOnlyBannerBackgroundBrush" Color="#FF242424" />
    <SolidColorBrush x:Key="ReadOnlyBannerBorderBrush" Color="#FF3A3A3A" />

    <!-- Agent chat bubbles -->
    <SolidColorBrush x:Key="AgentUserBubbleBrush" Color="#240078D4" />
    <SolidColorBrush x:Key="AgentAssistantBubbleBrush" Color="#12808080" />
    <SolidColorBrush x:Key="AgentToolBubbleBrush" Color="#198C8C8C" />
    <SolidColorBrush x:Key="AgentBubbleBorderBrush" Color="#24505050" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="AppErrorTextBrush" Color="#FFFFB4AB" />
    <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#FF332A1A" />
    <SolidColorBrush x:Key="StatusWarningBorderBrush" Color="#FF6D5830" />
    <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#FF3A1E1E" />
    <SolidColorBrush x:Key="StatusErrorBorderBrush" Color="#FF7A3737" />
    <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#FF173222" />
    <SolidColorBrush x:Key="StatusSuccessBorderBrush" Color="#FF2E6E47" />

</ResourceDictionary>
