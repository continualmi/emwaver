<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App-wide contrast -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppTextForegroundBrush" Color="#FF1F2328" />
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#FF57606A" />
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource AppTextForegroundBrush}" />
    </Style>

    <!-- Editor surfaces -->
    <SolidColorBrush x:Key="EditorSurfaceBackgroundBrush" Color="#FFF7F8FA" />
    <SolidColorBrush x:Key="EditorSurfaceBorderBrush" Color="#FFD8DEE4" />
    <SolidColorBrush x:Key="EditorTextForegroundBrush" Color="#FF1F2328" />

    <!-- Preview surfaces -->
    <SolidColorBrush x:Key="PreviewSurfaceBackgroundBrush" Color="#FFFBFCFD" />
    <SolidColorBrush x:Key="PreviewSurfaceBorderBrush" Color="#FFD8DEE4" />

    <!-- Generated content surfaces -->
    <SolidColorBrush x:Key="GeneratedSurfaceBackgroundBrush" Color="#FFF7F8FA" />
    <SolidColorBrush x:Key="GeneratedSurfaceBorderBrush" Color="#FFD8DEE4" />
    <SolidColorBrush x:Key="GeneratedDividerBrush" Color="#FFD8DEE4" />

    <!-- Plot -->
    <SolidColorBrush x:Key="PlotLineBrush" Color="#FF005FB8" />

    <!-- Script list pills / read-only banner -->
    <SolidColorBrush x:Key="ScriptPillExampleBackgroundBrush" Color="#FFEAF4FF" />
    <SolidColorBrush x:Key="ScriptPillExampleForegroundBrush" Color="#FF005FB8" />
    <SolidColorBrush x:Key="ScriptPillLibraryBackgroundBrush" Color="#FFF3E8FF" />
    <SolidColorBrush x:Key="ScriptPillLibraryForegroundBrush" Color="#FF6F2DA8" />
    <SolidColorBrush x:Key="ScriptPillKernelBackgroundBrush" Color="#FFFFF4CE" />
    <SolidColorBrush x:Key="ScriptPillKernelForegroundBrush" Color="#FF7A4D00" />
    <SolidColorBrush x:Key="ScriptPillCustomBackgroundBrush" Color="#FFE8F5E9" />
    <SolidColorBrush x:Key="ScriptPillCustomForegroundBrush" Color="#FF1E6B37" />
    <SolidColorBrush x:Key="ScriptPillOverrideBackgroundBrush" Color="#FFFFECE8" />
    <SolidColorBrush x:Key="ScriptPillOverrideForegroundBrush" Color="#FFB42318" />
    <SolidColorBrush x:Key="ReadOnlyBannerBackgroundBrush" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="ReadOnlyBannerBorderBrush" Color="#FFD0D7DE" />

    <!-- Status colors -->
    <SolidColorBrush x:Key="AppErrorTextBrush" Color="#FFB42318" />
    <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#FFFFF4CE" />
    <SolidColorBrush x:Key="StatusWarningBorderBrush" Color="#FFE5C365" />
    <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#FFFDECEC" />
    <SolidColorBrush x:Key="StatusErrorBorderBrush" Color="#FFF2B8B5" />
    <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#FFE8F5E9" />
    <SolidColorBrush x:Key="StatusSuccessBorderBrush" Color="#FFA5D6A7" />

</ResourceDictionary>
