<Window
    x:Class="EMWaver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver"
    Title="EMWaver">

    <Grid x:Name="RootGrid" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid Padding="10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- App icon (rounded) shown in the top app bar -->
            <Border
                Grid.Column="0"
                Width="24"
                Height="24"
                Margin="0,0,10,0"
                CornerRadius="6"
                Background="Transparent"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/emwaver.ico" Stretch="UniformToFill" />
            </Border>

            <!-- Device status button (replaces "Device" menu; shows connection + version) -->
            <Button Grid.Column="1" x:Name="DeviceMenuButton" Padding="10,6" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <SymbolIcon
                        x:Name="CableIconConnected"
                        Symbol="Link"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="Collapsed" />

                    <SymbolIcon
                        x:Name="CableIconDisconnected"
                        Symbol="Cancel"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="Visible" />

                    <TextBlock x:Name="DeviceStatusText" Text="Disconnected" />
                    <TextBlock x:Name="DeviceVersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Settings" Click="OnSettingsClick" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Refresh Ports" Click="OnRefreshPortsClick" />
                        <ToggleMenuFlyoutItem x:Name="AutoConnectMenuItem" Text="Auto-connect" Click="OnAutoConnectClick" />

                        <MenuFlyoutSeparator />

                        <MenuFlyoutSubItem x:Name="ConnectSubmenu" Text="Connect" />
                        <MenuFlyoutItem Text="Disconnect" Click="OnDisconnectClick" />

                        <MenuFlyoutSeparator />

                        <MenuFlyoutItem Text="Enter Update Mode" Click="OnEnterUpdateModeClick" />
                        <MenuFlyoutItem Text="Refresh Update Mode" Click="OnRefreshUpdateModeClick" />
                        <MenuFlyoutItem Text="Update Firmware…" Click="OnUpdateFirmwareClick" />
                        <MenuFlyoutItem x:Name="UpdateModeStatusItem" Text="Update Mode: Not detected" IsEnabled="False" />

                        <MenuFlyoutSeparator />

                        <MenuFlyoutItem x:Name="LastErrorMenuItem" Text="" IsEnabled="False" Visibility="Collapsed" />
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <CommandBar x:Name="AppCommandBar" DefaultLabelPosition="Collapsed">
                    <AppBarButton x:Name="BackButton" Label="Back" Icon="Back" Click="OnBackClick" IsEnabled="False" />
                    <AppBarButton x:Name="SettingsButton" Label="Settings" Icon="Setting" Click="OnTopSettingsClick" />
                </CommandBar>

                <CommandBar x:Name="ScriptsCommandBar" DefaultLabelPosition="Collapsed">
                    <!-- Mode toggles (Preview replaces editor region) -->
                    <AppBarToggleButton x:Name="ScriptEditToggleButton" Label="Code" IsEnabled="False"
                                        Checked="OnScriptEditChecked">
                        <AppBarToggleButton.Icon>
                            <SymbolIcon Symbol="Document" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>

                    <AppBarToggleButton x:Name="ScriptPreviewToggleButton" Label="Run" IsEnabled="False"
                                        Checked="OnScriptPreviewChecked">
                        <AppBarToggleButton.Icon>
                            <SymbolIcon Symbol="Play" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>

                    <AppBarSeparator />

                    <AppBarButton x:Name="ScriptNewButton" Label="New" Icon="Add" Click="OnScriptNewClick" />
                    <AppBarButton x:Name="ScriptSaveButton" Label="Save" Icon="Save" Click="OnScriptSaveClick" IsEnabled="False" />
                    <AppBarButton x:Name="ScriptCopyButton" Label="Copy" Icon="Copy" Click="OnScriptCopyClick" IsEnabled="False" />
                    <AppBarButton x:Name="ScriptRenameButton" Label="Rename" Icon="Edit" Click="OnScriptRenameClick" IsEnabled="False" />
                    <AppBarButton x:Name="ScriptDeleteButton" Label="Delete" Icon="Delete" Click="OnScriptDeleteClick" IsEnabled="False" />

                    <AppBarSeparator />

                    <AppBarToggleButton x:Name="ScriptAgentToggleButton" Label="Agent" Click="OnScriptAgentToggleClick">
                        <AppBarToggleButton.Icon>
                            <SymbolIcon Symbol="Message" />
                        </AppBarToggleButton.Icon>
                    </AppBarToggleButton>
                </CommandBar>

                <!-- Device status moved to the left (DeviceMenuButton) -->
            </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Window>
