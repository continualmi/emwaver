<Window
    x:Class="EMWaver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:EMWaver.Views"
    Title="EMWaver"
    Width="1100" Height="720"
    MinWidth="800" MinHeight="500">

    <Grid Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Product title and app build/version for support reports. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="EMWaver" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock x:Name="AppVersionText"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               VerticalAlignment="Center"
                               FontSize="11" Margin="8,1,0,0" />
                </StackPanel>

                <!-- Device picker -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Button x:Name="DeviceMenuButton" Click="OnDeviceMenuClick"
                            Padding="8,4" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DeviceIconText" Text="⚡" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock x:Name="DeviceStatusText" Text="Disconnected" VerticalAlignment="Center" FontSize="13" />
                            <TextBlock x:Name="DeviceVersionText" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Action toolbar -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Script mode toggles -->
                    <ToggleButton x:Name="CodeModeToggle" Content="Code" Width="60" Height="28"
                                  IsChecked="True" Click="OnCodeModeClick" Margin="0,0,2,0" />
                    <ToggleButton x:Name="PreviewModeToggle" Content="Preview" Width="70" Height="28"
                                  IsChecked="False" Click="OnPreviewModeClick" Margin="0,0,8,0" />

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

                    <!-- Running indicator -->
                    <Border x:Name="RunningIndicator" Visibility="Collapsed"
                            CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource EditorSurfaceBorderBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="RunningPulseDot" Width="8" Height="8" Fill="#42D17C" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock x:Name="RunningScriptText" Text="Running" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="StopButton" Content="⏹" Width="36" Height="28" ToolTip="Stop"
                            Click="OnStopClick" Visibility="Collapsed" />

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

                    <ToggleButton x:Name="AgentToggle" Content="Agent" Width="60" Height="28"
                                  IsChecked="False" Click="OnAgentToggleClick" Margin="0,0,6,0" />

                    <!-- Action buttons -->
                    <Button Content="New" Width="50" Height="28" Click="OnNewClick" Margin="0,0,2,0" />
                    <Button Content="Save" Width="50" Height="28" Click="OnSaveClick" Margin="0,0,2,0" />
                    <Button x:Name="MoreButton" Content="⋯" Width="36" Height="28" Margin="0,0,2,0" Click="OnMoreClick">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Make Copy" Click="OnMakeCopyClick" />
                                <MenuItem Header="Rename" Click="OnRenameClick" />
                                <MenuItem Header="Delete" Click="OnDeleteClick" />
                                <Separator />
                                <MenuItem Header="Check for Updates…" Click="OnCheckForUpdatesClick" />
                                <MenuItem Header="Settings…" Click="OnSettingsClick" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="Settings" Width="70" Height="28" Click="OnSettingsClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main surface: ScriptsView fills the window -->
        <views:ScriptsView x:Name="ScriptsViewControl" Grid.Row="1" />
    </Grid>
</Window>
