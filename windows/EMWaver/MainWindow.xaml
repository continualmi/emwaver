<Window
    x:Class="EMWaver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver"
    Title="EMWaver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <MenuBar>
                <MenuBarItem Title="Device">
                    <MenuFlyoutItem Text="Refresh Ports" Click="OnRefreshPortsClick" />
                    <ToggleMenuFlyoutItem x:Name="AutoConnectMenuItem" Text="Auto-connect" Click="OnAutoConnectClick" />

                    <MenuFlyoutSeparator />

                    <MenuFlyoutSubItem x:Name="ConnectSubmenu" Text="Connect" />
                    <MenuFlyoutItem Text="Disconnect" Click="OnDisconnectClick" />

                    <MenuFlyoutSeparator />

                    <MenuFlyoutItem Text="Enter Update Mode" Click="OnEnterUpdateModeClick" />
                    <MenuFlyoutItem Text="Refresh Update Mode" Click="OnRefreshUpdateModeClick" />
                    <MenuFlyoutItem x:Name="UpdateModeStatusItem" Text="Update Mode: Not detected" IsEnabled="False" />

                    <MenuFlyoutSeparator />

                    <MenuFlyoutItem x:Name="LastErrorMenuItem" Text="" IsEnabled="False" Visibility="Collapsed" />
                </MenuBarItem>
            </MenuBar>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="DeviceStatusText" Text="Disconnected" />
                <TextBlock x:Name="DeviceVersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="DeviceBufferText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Window>
