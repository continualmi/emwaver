<Window
    x:Class="EMWaver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EMWaver"
    Title="EMWaver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarToggleButton x:Name="ScriptsToggle" Label="Scripts" IsChecked="True" Click="OnScriptsClick" />
            <AppBarToggleButton x:Name="DeviceToggle" Label="Device" Click="OnDeviceClick" />

            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Refresh Ports" Click="OnRefreshPortsClick" />
                <AppBarToggleButton x:Name="AutoConnectToggle" Label="Auto-connect" Click="OnAutoConnectClick" />

                <AppBarButton x:Name="ConnectButton" Label="Connect">
                    <AppBarButton.Flyout>
                        <MenuFlyout x:Name="ConnectFlyout" />
                    </AppBarButton.Flyout>
                </AppBarButton>

                <AppBarButton Label="Disconnect" Click="OnDisconnectClick" />
                <AppBarButton Label="Enter Update Mode" Click="OnEnterUpdateModeClick" />
                <AppBarButton Label="Refresh Update Mode" Click="OnRefreshUpdateModeClick" />
            </CommandBar.SecondaryCommands>

            <CommandBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="DeviceStatusText" Text="Disconnected" />
                    <TextBlock x:Name="DeviceVersionText" Foreground="Gray" />
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>

        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Window>
