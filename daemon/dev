#!/usr/bin/env bash
set -euo pipefail

# One-command dev runner (npm run dev equivalent) for the daemon CLI.
# - Builds emwaver
# - Runs the emwaver CLI with your args

cd "$(dirname "$0")"

# Fast incremental build
cargo build -q -p emwaver

# Run CLI
if [[ $# -eq 0 ]]; then
  echo "Usage: ./daemon/dev <emwaver-args>"
  echo "Examples:"
  echo "  ./daemon/dev devices"
  echo "  ./daemon/dev gateway"
  echo "  ./daemon/dev daemon status"
  exit 0
fi

exec cargo run -q -p emwaver -- "$@"
