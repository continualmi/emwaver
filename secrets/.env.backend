# Backend-only env
EMWAVER_AUTH_MODE=enabled
EMWAVER_AUTH_DEBUG=0
CORS_ORIGINS=*
PORT=8787
FLASK_APP=emw_backend.app
DATABASE_URL=sqlite:///./emwaver.db

# LLM provider
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
GEMINI_API_KEY=

# Firebase admin/auth
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_JSON_B64=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe / billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STORE_STRIPE_PRICE_ID=
STORE_SUCCESS_URL=
STORE_CANCEL_URL=
STORE_SHIPPING_COUNTRIES=
PRO_STRIPE_PRICE_ID=
PRO_SUCCESS_URL=
PRO_CANCEL_URL=

# Azure blob storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_BLOB_CONTAINER=emwaver-user-files
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# Provisioning (PRIVATE; backend/provisioning only)
EMWAVER_PROVISIONING_ENABLED=0
EMWAVER_PROVISIONING_ROOT_PRIVATE_KEY_B64=
EMWAVER_PROVISIONING_ALLOWED_UIDS=
EMWAVER_PROVISIONING_ALLOWED_EMAIL=
EMWAVER_PROVISIONING_MINT_RPM=60

RUST_LOG=
