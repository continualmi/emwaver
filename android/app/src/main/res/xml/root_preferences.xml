<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Sampler Settings"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="sampler_invert_recording"
            android:title="Invert Capture During Recording"
            android:summary="Only affects Sampler while recording (0↔1)."
            android:defaultValue="false"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="refresh_time"
            android:title="Refresh Time"
            android:summary="Select the refresh time interval for the sampler"
            android:defaultValue="50"
            android:entries="@array/refresh_time_entries"
            android:entryValues="@array/refresh_time_values"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="buffer_size_limit"
            android:title="Buffer Size Limit"
            android:summary="Set maximum buffer size for sampling (each sample is 10µs)"
            android:defaultValue="393216"
            android:entries="@array/buffer_size_limit_entries"
            android:entryValues="@array/buffer_size_limit_values"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="ISM Settings"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="rfm69_cs_pin"
            android:title="RFM69 CS Pin"
            android:summary="Chip Select pin for RFM69 SPI communication"
            android:defaultValue="36"
            android:inputType="number"
            app:iconSpaceReserved="false"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="rfm69_cs_active_high"
            android:title="RFM69 CS Active High"
            android:summary="Enable if CS is active high (select=high, deselect=low)"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Support &amp; Information"
        app:iconSpaceReserved="false">

        <Preference
            android:key="help_documentation"
            android:title="Help &amp; Documentation"
            android:summary="Visit docs.emwaver.com for setup guides and tutorials"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://docs.emwaver.com" />
        </Preference>

        <Preference
            android:key="privacy_policy"
            android:title="Privacy Policy"
            android:summary="View our privacy policy"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://emwaverpolicy.z6.web.core.windows.net/" />
        </Preference>

    </PreferenceCategory>

</PreferenceScreen> 
