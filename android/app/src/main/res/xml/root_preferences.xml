<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Support &amp; Information"
        app:iconSpaceReserved="false">

        <Preference
            android:key="help_documentation"
            android:title="Help &amp; Documentation"
            android:summary="Visit docs.emwaver.com for setup guides and tutorials"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://docs.emwaver.com" />
        </Preference>

        <Preference
            android:key="privacy_policy"
            android:title="Privacy Policy"
            android:summary="View our privacy policy"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://emwaverpolicy.z6.web.core.windows.net/" />
        </Preference>

    </PreferenceCategory>

    <PreferenceCategory
        android:key="staff_only_category"
        android:title="Staff Only"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="staff.backend.mode"
            android:title="Backend mode"
            android:entries="@array/staff_mode_entries"
            android:entryValues="@array/staff_mode_values"
            android:defaultValue="cloud"
            android:summary="Switch between cloud and local backend URLs"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="staff.frontend.mode"
            android:title="Frontend mode"
            android:entries="@array/staff_mode_entries"
            android:entryValues="@array/staff_mode_values"
            android:defaultValue="cloud"
            android:summary="Switch between cloud and local frontend URLs"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

</PreferenceScreen>
