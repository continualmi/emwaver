<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.flash.FlashFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/buttonConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request/Connect DFU"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/textViewBoot0Hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set BOOT0 to FLASH (DFU), then reconnect USB."
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:id="@+id/imageViewBoot0Diagram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:adjustViewBounds="true"
            android:contentDescription="BOOT0 switch positions for DFU and run mode"
            android:scaleType="fitCenter"
            android:src="@drawable/boot0_diagram" />

        <TextView
            android:id="@+id/textViewFirmwareLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STM32 bundled firmware:"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Spinner
            android:id="@+id/spinnerFirmware"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/textViewFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="dfu/ism.dfu"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/buttonFlashFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Flash STM32 DFU"
            android:enabled="false"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/textViewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#33000000" />

        <TextView
            android:id="@+id/textViewOtaLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32 OTA"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <RadioGroup
            android:id="@+id/radioGroupOtaTransport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioOtaBle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="BLE" />

            <RadioButton
                android:id="@+id/radioOtaWifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Wi‑Fi SoftAP" />

        </RadioGroup>

        <Button
            android:id="@+id/buttonOtaWifiStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Wi‑Fi OTA Mode"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/buttonOtaWifiSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Wi‑Fi Settings"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/textViewOtaFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ota/emwaveresp.bin"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/buttonOtaFlashStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Flash Stock OTA"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/buttonOtaSelectBin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose .bin…"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/buttonOtaFlashSelected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Flash Selected OTA"
            android:enabled="false"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/textViewOtaStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

    </LinearLayout>
</ScrollView>
