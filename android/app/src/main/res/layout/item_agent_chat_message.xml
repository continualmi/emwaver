<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:viewBindingIgnore="true"
    android:id="@+id/agent_chat_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Agent message bubble (left-aligned, with Markwon for markdown) -->
    <LinearLayout
        android:id="@+id/agent_chat_bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="320dp"
        android:background="@drawable/agent_message_bubble"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <!-- Tool bubble header (shown for system/tool messages) -->
        <LinearLayout
            android:id="@+id/agent_chat_tool_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/agent_chat_tool_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/agent_chat_tool_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/agent_chat_tool_expand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▸"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"
                android:paddingStart="6dp" />

        </LinearLayout>

        <!-- Tool details (expandable) -->
        <LinearLayout
            android:id="@+id/agent_chat_tool_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/agent_chat_tool_args_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arguments"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agent_chat_tool_args"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="#0D000000"
                android:textColor="@color/textPrimary"
                android:padding="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agent_chat_tool_output_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Output"
                android:textSize="10sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agent_chat_tool_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="#0D000000"
                android:textColor="@color/textPrimary"
                android:padding="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agent_chat_tool_error_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Error"
                android:textSize="10sp"
                android:textColor="@color/destructiveAction"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/agent_chat_tool_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:background="#1AB3261E"
                android:textColor="@color/destructiveAction"
                android:padding="6dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Regular message text (hidden for tool messages, used for agent/user text) -->
        <TextView
            android:id="@+id/agent_chat_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/textPrimary"
            android:textIsSelectable="true" />

    </LinearLayout>

    <!-- User message bubble (right-aligned, accent background) -->
    <LinearLayout
        android:id="@+id/agent_chat_user_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:background="@drawable/user_message_bubble"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/agent_chat_user_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:textColor="@android:color/white"
            android:textIsSelectable="true" />

    </LinearLayout>

</FrameLayout>
