<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@color/surfaceBackground"
    tools:context=".ui.scripts.ScriptsFragment">

    <LinearLayout
        android:id="@+id/scripts_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/script_target_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Target: active device"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/textSecondary"
            android:background="@color/surfaceBackground" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="260dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp"
            app:cardBackgroundColor="@color/surfaceCard">

            <ListView
                android:id="@+id/scripts_list_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surfaceCard" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/script_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:foregroundGravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:background="@color/surfaceCard"
        app:layout_constraintTop_toBottomOf="@id/scripts_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/remote_control_banner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Remote control active"
            android:textSize="12sp"
            android:textColor="@color/textPrimary"
            android:backgroundTint="@color/surfaceCard"
            android:background="@drawable/rounded_background"
            android:visibility="gone" />

        <TextView
            android:id="@+id/script_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Render a script to preview it here."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/textSecondary"
            android:gravity="center"
            android:padding="24dp"
            android:drawablePadding="8dp"
            android:layout_gravity="center"
            android:textAlignment="center" />

        <ProgressBar
            android:id="@+id/script_progress"
            style="@style/Widget.AppCompat.ProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center" />
    </FrameLayout>
    <FrameLayout
        android:id="@+id/script_editor_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/surfaceBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/editor_scroll_view_wrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/script_editor_content_wrap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="false"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:textSize="12sp" />

        </ScrollView>

        <HorizontalScrollView
            android:id="@+id/editor_scroll_view_nowrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="horizontal">

            <!--
                HorizontalScrollView does not provide vertical fling.
                Wrap the editor in a ScrollView so vertical scrolling has momentum.
            -->
            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <EditText
                    android:id="@+id/script_editor_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="280dp"
                    android:gravity="top|start"
                    android:fontFamily="monospace"
                    android:padding="16dp"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:scrollHorizontally="true"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textSecondary"
                    android:textSize="12sp" />

            </ScrollView>

        </HorizontalScrollView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
