<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@color/surfaceBackground"
    tools:context=".ui.scripts.ScriptsFragment">

    <!-- Asset Scripts Section -->
    <TextView
        android:id="@+id/asset_scripts_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Asset Scripts (Read-Only)"
        android:textStyle="bold"
        android:textSize="15sp"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:drawableEnd="@drawable/ic_arrow_down_black"
        android:drawablePadding="8dp"
        android:textColor="@color/textPrimary"
        android:drawableTint="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/asset_scripts_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="4dp"
        app:cardBackgroundColor="@color/surfaceCard"
        app:layout_constraintTop_toBottomOf="@id/asset_scripts_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/asset_scripts_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surfaceCard" />
    </androidx.cardview.widget.CardView>

    <!-- Custom Scripts Section -->
    <TextView
        android:id="@+id/custom_scripts_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Custom Scripts"
        android:textStyle="bold"
        android:textSize="15sp"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:drawableEnd="@drawable/ic_arrow_down_black"
        android:drawablePadding="8dp"
        android:textColor="@color/textPrimary"
        android:drawableTint="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"
        app:layout_constraintTop_toBottomOf="@id/asset_scripts_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/custom_scripts_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="4dp"
        app:cardBackgroundColor="@color/surfaceCard"
        app:layout_constraintTop_toBottomOf="@id/custom_scripts_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/custom_scripts_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surfaceCard" />
    </androidx.cardview.widget.CardView>

    <FrameLayout
        android:id="@+id/script_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:foregroundGravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:background="@color/surfaceCard"
        app:layout_constraintTop_toBottomOf="@id/custom_scripts_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/script_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Render a script to preview it here."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@color/textSecondary"
            android:gravity="center"
            android:padding="24dp"
            android:drawablePadding="8dp"
            android:layout_gravity="center"
            android:textAlignment="center" />

        <ProgressBar
            android:id="@+id/script_progress"
            style="@style/Widget.AppCompat.ProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center" />
    </FrameLayout>
    <FrameLayout
        android:id="@+id/script_editor_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@color/surfaceBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/editor_scroll_view_wrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/script_editor_content_wrap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="false"
                android:textColor="@color/codeText"
                android:textColorHint="@color/textSecondary"
                android:textSize="12sp" />

        </ScrollView>

        <HorizontalScrollView
            android:id="@+id/editor_scroll_view_nowrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="horizontal">

            <EditText
                android:id="@+id/script_editor_content"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:minWidth="280dp"
                android:gravity="top|start"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:inputType="textMultiLine|textNoSuggestions"
                android:scrollHorizontally="true"
                android:textColor="@color/codeText"
                android:textColorHint="@color/textSecondary"
                android:textSize="12sp" />

        </HorizontalScrollView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
