<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/update_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Update EMWaver"
            android:textStyle="bold"
            android:textSize="18sp" />

        <Button
            android:id="@+id/close_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close" />
    </LinearLayout>

    <TextView
        android:id="@+id/update_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Update your device to the latest EMWaver version." />

    <LinearLayout
        android:id="@+id/esp_target_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="12dp"
        android:orientation="vertical"
        android:background="@color/surfaceCard"
        android:visibility="gone">

        <TextView
            android:id="@+id/esp_target_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP firmware target"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/esp_target_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/esp_target_help"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select the exact ESP family before flashing from serial bootloader mode." />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/instructions_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="12dp"
        android:orientation="vertical"
        android:background="@color/surfaceCard">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 — Enter Update Mode"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/enter_update_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Warning: this will switch the device to the STM32 ROM bootloader. The device will be unusable until you re-flash firmware. You will need to unplug and plug it back in to continue the update."
            android:textColor="@android:color/holo_orange_dark" />

        <Button
            android:id="@+id/enter_update_mode_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Enter Update Mode"
            android:enabled="false" />

        <TextView
            android:id="@+id/dfu_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Step 2 — Unplug and plug back in. When ‘Device connected in Update Mode’ appears, you can flash firmware."
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/dfu_connected_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="12dp"
        android:background="@color/surfaceCard"
        android:text="Device connected in Update Mode."
        android:visibility="gone" />

    <TextView
        android:id="@+id/update_error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/progress_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="" />

            <TextView
                android:id="@+id/progress_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <TextView
        android:id="@+id/update_done_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="12dp"
        android:background="@color/surfaceCard"
        android:text="Update complete. Unplug the device and reconnect (Run mode)."
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/update_device_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flash firmware"
            android:enabled="false" />
    </LinearLayout>

</LinearLayout>
