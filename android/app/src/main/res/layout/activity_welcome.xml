<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- App Icon/Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="EMWaver Logo" />

        <!-- Welcome Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to EMWaver!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Thank you message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thank you for downloading EMWaver"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Main description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You'll need an EMWaver hardware device - a versatile ESP32-S3 board that connects via Bluetooth."
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="12dp" />

        <!-- Features description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Features CC1101 for sub-GHz RF, infrared, and 16 GPIO pins."
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="32dp" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Documentation Button -->
        <Button
            android:id="@+id/btn_documentation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 Documentation &amp; Setup"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="@color/design_default_color_primary"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- Get Started Button -->
        <Button
            android:id="@+id/btn_get_started"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➡️ Get Started"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="#4CAF50"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</ScrollView> 