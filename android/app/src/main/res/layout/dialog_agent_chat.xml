<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header bar: conversations / new / clear -->
        <LinearLayout
            android:id="@+id/agent_chat_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_conversations"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chats"
                android:textColor="@color/colorAccent"
                app:icon="@drawable/ai_collection"
                app:iconSize="18dp" />

            <androidx.legacy.widget.Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_new"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New"
                android:textColor="@color/colorAccent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_clear"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="@color/colorAccent" />

        </LinearLayout>

        <!-- Pro / API-key notice bar -->
        <LinearLayout
            android:id="@+id/agent_chat_pro_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/agent_message_bubble"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒 Add an MGPT API key to enable Agent replies."
                android:textSize="13sp"
                android:textColor="@color/textSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_get_key"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Get Free Key…"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Suggestion cards (shown when no messages) -->
        <LinearLayout
            android:id="@+id/agent_chat_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/agent_suggestion_usb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:padding="10dp"
                android:background="@drawable/agent_message_bubble"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ai_usb" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="How do I connect an EMWaver device over USB?"
                    android:textSize="12sp"
                    android:textColor="@color/textPrimary"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/agent_suggestion_script"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:padding="10dp"
                android:background="@drawable/agent_message_bubble"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ai_chip" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Help me write a script for a connected board."
                    android:textSize="12sp"
                    android:textColor="@color/textPrimary"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/agent_suggestion_gpio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:padding="10dp"
                android:background="@drawable/agent_message_bubble"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ai_bluetooth" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Help me write a script to blink a GPIO pin."
                    android:textSize="12sp"
                    android:textColor="@color/textPrimary"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/agent_suggestion_ir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:padding="10dp"
                android:background="@drawable/agent_message_bubble"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ai_wifi" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="How do I capture and replay an IR remote?"
                    android:textSize="12sp"
                    android:textColor="@color/textPrimary"
                    android:maxLines="3"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>

        <!-- Error bubble (shown in-stream when there's an error) -->
        <LinearLayout
            android:id="@+id/agent_chat_error_bubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:padding="12dp"
            android:background="@drawable/agent_chat_error_bg"
            android:visibility="gone">

            <TextView
                android:id="@+id/agent_chat_error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/destructiveAction"
                android:textIsSelectable="true" />

        </LinearLayout>

        <!-- Message list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/agent_chat_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp"
            android:scrollbars="vertical" />

        <!-- Loading overlay (centered) -->
        <FrameLayout
            android:id="@+id/agent_chat_loading_overlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/agent_message_bubble"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp">

                <ProgressBar
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminate="true"
                    style="?android:attr/progressBarStyle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Loading…"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary" />

            </LinearLayout>

        </FrameLayout>

        <!-- Composer area -->
        <LinearLayout
            android:id="@+id/agent_chat_composer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:padding="12dp"
            android:background="@color/surfaceCard"
            android:elevation="4dp">

            <EditText
                android:id="@+id/agent_chat_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:hint="Message"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="6"
                android:minHeight="40dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:background="@drawable/agent_chat_input_bg"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/textSecondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_send"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="Send"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/colorAccent"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/agent_chat_stop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="Stop"
                android:textColor="@color/destructiveAction"
                app:strokeColor="@color/destructiveAction"
                app:cornerRadius="12dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scroll-to-bottom FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/agent_chat_scroll_fab"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="Scroll to bottom"
        android:visibility="gone"
        app:srcCompat="@drawable/ai_play"
        app:fabSize="mini"
        app:backgroundTint="@color/surfaceCard"
        app:borderWidth="0dp"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
