<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="#E0E0E0"
    tools:context=".ui.wavelets.WaveletsFragment">

    <TextView
        android:id="@+id/scripts_list_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Available Scripts"
        android:textAppearance="?attr/textAppearanceListItemSmall"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        android:drawableEnd="@drawable/ic_arrow_down_black"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/script_list_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxHeight="150dp"
        android:layout_marginTop="4dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="4dp"
        app:layout_constraintTop_toBottomOf="@id/scripts_list_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/script_list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/script_editor_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Script Editor"
        android:textStyle="bold"
        android:textSize="16sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#0277BD"
        android:padding="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:drawableEnd="@drawable/ic_arrow_down_black"
        android:drawablePadding="8dp"
        app:layout_constraintTop_toBottomOf="@id/script_list_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/script_editor_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="4dp"
        app:layout_constraintTop_toBottomOf="@id/script_editor_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/wavelet_container"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintHeight_percent="0.4">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF">

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/jsCodeInput"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:autofillHints=""
                    android:fontFamily="monospace"
                    android:gravity="start|top"
                    android:hint="// Your script here..."
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:padding="16dp"
                    android:scrollHorizontally="true"
                    android:text=""
                    android:textColor="#003D99"
                    android:textColorHint="#ABABAB"
                    android:textSize="11sp"
                    tools:ignore="LabelFor" />

            </HorizontalScrollView>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <FrameLayout
        android:id="@+id/wavelet_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:foregroundGravity="center"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/script_editor_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/wavelet_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Render a wavelet to preview it here."
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="@android:color/darker_gray"
            android:gravity="center"
            android:padding="24dp"
            android:drawablePadding="8dp"
            android:layout_gravity="center"
            android:textAlignment="center" />

        <ProgressBar
            android:id="@+id/wavelet_progress"
            style="@style/Widget.AppCompat.ProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center" />
    </FrameLayout>

    <androidx.constraintlayout.widget.Group
        android:id="@+id/editor_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="scripts_list_title,script_list_card,script_editor_title,script_editor_card" />

</androidx.constraintlayout.widget.ConstraintLayout>
