<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night mode application theme. -->
    <style name="Theme.Irwaver" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/surfaceBackground</item>
        <item name="colorSurface">@color/surfaceCard</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
        <item name="android:navigationBarColor">@color/surfaceBackground</item>
        <item name="android:colorBackground">@color/surfaceBackground</item>
        <item name="android:colorForeground">@color/textPrimary</item>
        <item name="android:listDivider">@color/surfaceMuted</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
