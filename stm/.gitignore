# STM32CubeIDE outputs
**/Debug/
**/Release/

# Keep EMWaver's canonical STM32 make build dirs in-repo (used by `emwaver build`).
!emwaver-firmware/Debug/
!emwaver-firmware/Release/

# Keep makefile metadata, ignore build artifacts.
!emwaver-firmware/Debug/makefile
!emwaver-firmware/Debug/*.mk
!emwaver-firmware/Debug/objects.list
!emwaver-firmware/Debug/**/subdir.mk
!emwaver-firmware/Release/makefile
!emwaver-firmware/Release/*.mk
!emwaver-firmware/Release/objects.list
!emwaver-firmware/Release/**/subdir.mk

# Eclipse / CubeIDE metadata
**/.settings/
**/.metadata/
