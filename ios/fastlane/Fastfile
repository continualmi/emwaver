opt_out_usage

default_platform(:ios)

platform :ios do
  before_all do
    ENV["FASTLANE_SKIP_UPDATE_CHECK"] = "1"
  end

  desc "Run iOS tests on the default simulator"
  lane :test do
    scan(
      project: "EMWaver.xcodeproj",
      scheme: "EMWaver",
      configuration: "Debug",
      device: ENV.fetch("EMWAVER_IOS_TEST_DEVICE", "iPhone 16"),
      clean: true
    )
  end

  desc "Archive the iOS app without uploading"
  lane :archive do
    configure_ci_app_store_signing

    build_app(
      project: "EMWaver.xcodeproj",
      scheme: "EMWaver",
      configuration: "Release",
      export_options: export_options_path,
      output_directory: "../build/ios",
      output_name: "EMWaver.ipa",
      clean: true,
      xcargs: xcode_args
    )

    validate_ios_bundle_assets
  end

  desc "Compatibility alias for release_upload"
  lane :beta do
    release_upload
  end

  desc "Build and upload an iOS release build to App Store Connect/TestFlight processing"
  lane :release_upload do
    api_key = app_store_connect_api_key_from_env
    increment_build_number_for_upload(api_key: api_key)
    configure_ci_app_store_signing

    build_app(
      project: "EMWaver.xcodeproj",
      scheme: "EMWaver",
      configuration: "Release",
      export_options: export_options_path,
      output_directory: "../build/ios",
      output_name: "EMWaver.ipa",
      clean: true,
      xcargs: xcode_args
    )

    validate_ios_bundle_assets
    upload_binary_to_app_store_connect(api_key: api_key)
  end

  desc "Upload App Store metadata and the latest local IPA. Final App Review submission is still confirmed in App Store Connect."
  lane :release do
    api_key = app_store_connect_api_key_from_env

    upload_app_store_candidate(api_key: api_key)
  end

  desc "Compatibility alias for release_upload"
  lane :app_store_upload do
    release_upload
  end

  private_lane :upload_binary_to_app_store_connect do |options|
    upload_to_testflight(
      api_key: options[:api_key],
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH].to_s,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: changelog_text
    )
  end

  private_lane :validate_ios_bundle_assets do
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH].to_s
    ipa_path = File.expand_path("../build/ios/EMWaver.ipa", __dir__) if ipa_path.empty?
    UI.user_error!("Missing IPA for bundle validation: #{ipa_path}") unless File.exist?(ipa_path)

    sh(%Q(
      set -euo pipefail
      tmp_dir="$(mktemp -d)"
      trap 'rm -rf "${tmp_dir}"' EXIT
      unzip -q "#{ipa_path}" -d "${tmp_dir}"
      app_dir="$(find "${tmp_dir}/Payload" -maxdepth 1 -name '*.app' -type d | head -1)"
      test -n "${app_dir}" || (echo "Missing .app inside IPA" >&2; exit 1)
      test -f "${app_dir}/DefaultScripts/emw-kernel.js" || (echo "Missing DefaultScripts/emw-kernel.js in IPA" >&2; exit 1)
      js_count="$(find "${app_dir}/DefaultScripts" -maxdepth 1 -name '*.js' -type f | wc -l | tr -d ' ')"
      test "${js_count}" -ge 5 || (echo "Expected bundled JavaScript default scripts, found ${js_count}" >&2; exit 1)
      if find "${app_dir}" -name '*.emw' -type f | grep -q .; then
        echo "IPA still contains legacy .emw scripts:" >&2
        find "${app_dir}" -name '*.emw' -type f >&2
        exit 1
      fi
      if find "${app_dir}" -name 'script_bootstrap.emw' -type f | grep -q .; then
        echo "IPA still contains legacy script_bootstrap.emw" >&2
        exit 1
      fi
      echo "Validated IPA script assets: ${js_count} JavaScript files and no legacy .emw files."
    ))
  end

  private_lane :upload_app_store_candidate do |options|
    api_key = options[:api_key]

    deliver(
      api_key: api_key,
      ipa: "../build/ios/EMWaver.ipa",
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      submit_for_review: false,
      force: true,
      skip_binary_upload: !File.exist?("../build/ios/EMWaver.ipa"),
      skip_screenshots: !Dir.exist?("fastlane/screenshots"),
      run_precheck_before_submit: false
    )
  end

  private_lane :app_store_connect_api_key_from_env do
    required = %w[
      APP_STORE_CONNECT_API_KEY_ID
      APP_STORE_CONNECT_API_ISSUER_ID
      EMWAVER_APP_STORE_CONNECT_API_KEY_PATH
    ]
    missing = required.select { |key| ENV[key].to_s.empty? }
    UI.user_error!("Missing App Store Connect API env vars: #{missing.join(', ')}") unless missing.empty?

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_filepath: ENV.fetch("EMWAVER_APP_STORE_CONNECT_API_KEY_PATH"),
      in_house: false
    )
  end

  private_lane :increment_build_number_for_upload do |options|
    api_key = options[:api_key]
    next_build = ENV["EMWAVER_IOS_BUILD_NUMBER"].to_s.strip
    if next_build.empty?
      latest_build = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.emwaver.EMWaver",
        initial_build_number: 0
      )
      next_build = (latest_build.to_i + 1).to_s
    end

    increment_build_number(
      build_number: next_build,
      xcodeproj: "EMWaver.xcodeproj"
    )
  end

  private_lane :configure_ci_app_store_signing do
    profile_name = ENV.fetch("IOS_PROVISIONING_PROFILE_NAME", "").strip
    if profile_name.empty?
      UI.message("Using the signing settings already configured in Xcode.")
      next
    end

    update_code_signing_settings(
      path: "EMWaver.xcodeproj",
      targets: ["EMWaver"],
      build_configurations: ["Release"],
      use_automatic_signing: false,
      team_id: "9VA9KTUXXN",
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution"
    )
  end

  def changelog_text
    ENV.fetch("EMWAVER_IOS_CHANGELOG", "").strip
  end

  def export_options_path
    ENV.fetch("EMWAVER_IOS_EXPORT_OPTIONS", "exportOptions.plist")
  end

  def xcode_args
    ENV.fetch("EMWAVER_IOS_XCARGS", "DEVELOPMENT_TEAM=9VA9KTUXXN")
  end
end
