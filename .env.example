# EMWaver local development environment
#
# Copy this file to .env and fill in the values you need.
# The .env file is gitignored and never committed.

# --- Linux development (when running from source) ---
# Path to the shared bundled scripts directory. Required when running the
# Linux app directly from a source checkout so it can load built-in scripts.
# EMWAVER_DEFAULT_SCRIPTS_DIR=./assets/default-scripts

# Path to the bundled firmware directory. Required when running the Linux
# app from source so firmware update flows can find the binary payloads.
# EMWAVER_FIRMWARE_DIR=./firmware

# Path to the ESP helper source directory for ESP32 serial flashing.
# Optional; only needed when running the Linux app from source and you
# want the ESP32 flashing helper available without a packaged install.
# EMWAVER_ESP_HELPER_SOURCE=./tools/emwaver-esp-helper

# --- Manual Wi-Fi target (Linux development) ---
# Set these to add a manual LAN/VPN Wi-Fi target at app launch.
# EMWAVER_WIFI_HOST=192.168.1.100
# EMWAVER_WIFI_PORT=3922
