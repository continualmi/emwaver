UI.render(
  UI.column({
    padding: 16,
    spacing: 12,
    children: [
      UI.text({
        text: "hello",
      }),
    ],
  })
);

let level = LOW;
pinMode(GDO0, OUTPUT);
digitalWrite(GDO0, level);

every(250, function () {
  level = level === LOW ? HIGH : LOW;
  digitalWrite(GDO0, level);
});
