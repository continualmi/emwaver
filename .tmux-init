#!/usr/bin/env bash
SESSION=$1
PROJECT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Window 1: Terminal & Git
# Force the first pane to the correct directory just in case
tmux send-keys -t $SESSION:1 'cd ' "$PROJECT_DIR" C-m
tmux clear-history -t $SESSION:1

tmux rename-window -t $SESSION:1 'terminal'
tmux split-window -h -t $SESSION:1 -c "$PROJECT_DIR"
tmux send-keys -t $SESSION:1.2 'lazygit' C-m
tmux select-pane -t $SESSION:1.1

# Window 2: Dev Ops (2x2 Grid)
# All 4 panes: Backend, Android, vi (editor), Web

# Use pane_id capture so we don't depend on tmux's pane numbering.
PANE_TOP_LEFT=$(tmux new-window -t $SESSION -n 'dev-ops' -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Split horizontally: left (Backend) | right (Android)
PANE_TOP_RIGHT=$(tmux split-window -h -l 50% -t "$PANE_TOP_LEFT" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Split vertically: bottom-left (vi) from top-left
PANE_BOTTOM_LEFT=$(tmux split-window -v -l 50% -t "$PANE_TOP_LEFT" -c "$PROJECT_DIR" -P -F '#{pane_id}')
# Split vertically: bottom-right (Web) from top-right
PANE_BOTTOM_RIGHT=$(tmux split-window -v -l 50% -t "$PANE_TOP_RIGHT" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Assign commands
# Pre-type commands (not executed) except vi which runs
tmux send-keys -t "$PANE_TOP_LEFT" 'cd backend && python app.py'
tmux send-keys -t "$PANE_TOP_RIGHT" 'cd android && ./gradlew installDebug'
tmux send-keys -t "$PANE_BOTTOM_LEFT" 'vi .' C-m
tmux send-keys -t "$PANE_BOTTOM_RIGHT" 'cd frontend && npm run dev'

# Start on terminal window, pane 1
tmux select-window -t "$SESSION:1"
tmux select-pane -t "$SESSION:1.1"
tmux send-keys -t "$SESSION:1.1" 'opencode' C-m
