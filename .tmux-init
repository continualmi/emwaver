#!/usr/bin/env bash
SESSION=$1
PROJECT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Window 1: Terminal & Git
# Force the first pane to the correct directory just in case
tmux send-keys -t $SESSION:1 'cd ' "$PROJECT_DIR" C-m
tmux clear-history -t $SESSION:1

tmux rename-window -t $SESSION:1 'terminal'
tmux split-window -h -t $SESSION:1 -c "$PROJECT_DIR"
tmux send-keys -t $SESSION:1.2 'lazygit' C-m
tmux select-pane -t $SESSION:1.1

# Window 2: Dev Ops (Editor + 2x2 Grid)
# Left 1/3: vi
# Right 2/3: Backend/Firmware/Android/Web in a 2x2 grid (equal panes)

# Use pane_id capture so we don't depend on tmux's pane numbering.
PANE_EDITOR=$(tmux new-window -t $SESSION -n 'dev-ops' -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Split horizontally: Left (~1/6) | Right (~5/6)
# -p is the percentage size of the *new* pane.
PANE_RIGHT=$(tmux split-window -h -p 84 -t "$PANE_EDITOR" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Left: Editor
tmux send-keys -t "$PANE_EDITOR" 'vi .' C-m

# Right: make a 2x2 grid with equal halves
# Order matters: split right pane into top/bottom, then split each row into left/right.
PANE_RIGHT_BOTTOM=$(tmux split-window -v -p 50 -t "$PANE_RIGHT" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_RIGHT_TOP_RIGHT=$(tmux split-window -h -p 50 -t "$PANE_RIGHT" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_RIGHT_BOTTOM_RIGHT=$(tmux split-window -h -p 50 -t "$PANE_RIGHT_BOTTOM" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Assign commands
# Top-left of right grid: Backend (Flask)
tmux send-keys -t "$PANE_RIGHT" 'cd backend' C-m
tmux send-keys -t "$PANE_RIGHT" 'python app.py'

# Top-right of right grid: Android
tmux send-keys -t "$PANE_RIGHT_TOP_RIGHT" 'cd android' C-m
tmux send-keys -t "$PANE_RIGHT_TOP_RIGHT" './gradlew installDebug'

# Bottom-left of right grid: Firmware
tmux send-keys -t "$PANE_RIGHT_BOTTOM" 'cd stm/emwaver-firmware' C-m
tmux send-keys -t "$PANE_RIGHT_BOTTOM" 'emwaver build && emwaver flash'

# Bottom-right of right grid: Web (Next.js)
tmux send-keys -t "$PANE_RIGHT_BOTTOM_RIGHT" 'cd frontend' C-m
tmux send-keys -t "$PANE_RIGHT_BOTTOM_RIGHT" 'npm run dev'

# Start on terminal window, pane 1
tmux select-window -t "$SESSION:1"
tmux select-pane -t "$SESSION:1.1"
tmux send-keys -t "$SESSION:1.1" 'opencode' C-m
