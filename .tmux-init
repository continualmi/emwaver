#!/usr/bin/env bash
SESSION=$1
PROJECT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Window 1: Git (only thing that auto-runs)
# Force the first pane to the correct directory just in case
tmux send-keys -t $SESSION:1 'cd ' "$PROJECT_DIR" C-m
tmux clear-history -t $SESSION:1

tmux rename-window -t $SESSION:1 'git'
tmux send-keys -t $SESSION:1.1 'lazygit' C-m

# Window 2: Dev (Backend + Frontend) — auto-run
PANE_BACKEND=$(tmux new-window -t $SESSION -n 'dev' -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_FRONTEND=$(tmux split-window -h -l 50% -t "$PANE_BACKEND" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Backend
tmux send-keys -t "$PANE_BACKEND" 'cd backend' C-m
tmux send-keys -t "$PANE_BACKEND" 'python app.py' C-m

# Frontend
tmux send-keys -t "$PANE_FRONTEND" 'cd frontend' C-m
tmux send-keys -t "$PANE_FRONTEND" 'npm run dev' C-m

# Window 3: Dev Ops (2x2 Grid) — typed only
# Android | SecureWaver (tauri)
# emwaver.sh | emwaver daemon TUI

PANE_TOP_LEFT=$(tmux new-window -t $SESSION -n 'dev-ops' -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_TOP_RIGHT=$(tmux split-window -h -l 50% -t "$PANE_TOP_LEFT" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_BOTTOM_LEFT=$(tmux split-window -v -l 50% -t "$PANE_TOP_LEFT" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_BOTTOM_RIGHT=$(tmux split-window -v -l 50% -t "$PANE_TOP_RIGHT" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Typed only (no enter)
tmux send-keys -t "$PANE_TOP_LEFT" 'cd android && ./gradlew installDebug'
tmux send-keys -t "$PANE_TOP_RIGHT" 'cd securewaver && npm run tauri'
tmux send-keys -t "$PANE_BOTTOM_LEFT" './emwaver.sh '
tmux send-keys -t "$PANE_BOTTOM_RIGHT" './emwaver.sh tui'

# Window 4: Codex (2x2 Grid) — runs in all panes
PANE_CODEX_TL=$(tmux new-window -t $SESSION -n 'codex' -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_CODEX_TR=$(tmux split-window -h -l 50% -t "$PANE_CODEX_TL" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_CODEX_BL=$(tmux split-window -v -l 50% -t "$PANE_CODEX_TL" -c "$PROJECT_DIR" -P -F '#{pane_id}')
PANE_CODEX_BR=$(tmux split-window -v -l 50% -t "$PANE_CODEX_TR" -c "$PROJECT_DIR" -P -F '#{pane_id}')

# Run codex in all panes
for P in "$PANE_CODEX_TL" "$PANE_CODEX_TR" "$PANE_CODEX_BL" "$PANE_CODEX_BR"; do
  tmux send-keys -t "$P" 'codex' C-m
done

# Start on git window

tmux select-window -t "$SESSION:1"
tmux select-pane -t "$SESSION:1.1"
