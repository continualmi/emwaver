{
  "name": "emwaver",
  "displayName": "EMWaver",
  "description": "Wavelet preview + device connection helpers for EMWaver.",
  "version": "0.0.1",
  "publisher": "emwaver",
  "icon": "media/emwaver-logo.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:emwaver.buildFlashView",
    "onCommand:emwaver.connectDevice",
    "onCommand:emwaver.disconnectDevice",
    "onCommand:emwaver.sendDeviceCommand",
    "onCommand:emwaver.openBuildFlash",
    "onCommand:emwaver.previewWavelet",
    "onLanguage:emw"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "emwaver.openBuildFlash",
        "title": "EMWaver: Open Wavelets"
      },
      {
        "command": "emwaver.connectDevice",
        "title": "EMWaver: Connect Device"
      },
      {
        "command": "emwaver.disconnectDevice",
        "title": "EMWaver: Disconnect Device"
      },
      {
        "command": "emwaver.sendDeviceCommand",
        "title": "EMWaver: Send Device Command"
      },
      {
        "command": "emwaver.previewWavelet",
        "title": "EMWaver: Preview Wavelet"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "emwaver.previewWavelet",
          "when": "resourceExtname == .emw",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "EMWaver",
      "properties": {
        "emwaver.cliPath": {
          "type": "string",
          "default": "~/emwaver/cli/target/debug/emwaver",
          "description": "Path to the emwaver CLI executable (or just 'emwaver' if it is on PATH)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "emwaver",
          "title": "EMWaver",
          "icon": "media/emwaver-activity.svg"
        }
      ]
    },
    "views": {
      "emwaver": [
        {
          "id": "emwaver.buildFlashView",
          "name": "Wavelets",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "emw",
        "aliases": [
          "EMWaver Wavelet",
          "emw"
        ],
        "extensions": [
          ".emw"
        ],
        "mimetypes": [
          "text/javascript"
        ],
        "configuration": "./language-configuration.emw.json"
      }
    ],
    "grammars": [
      {
        "language": "emw",
        "scopeName": "source.emw",
        "path": "./syntaxes/emw.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "emwaver-icons-minimal",
        "label": "EMWaver Icons (minimal)",
        "path": "./emwaver-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4"
  },
  "license": "Apache-2.0"
}
