{
  "name": "emwaver",
  "displayName": "EMWaver",
  "description": "Build/flash helpers for EMWaver firmware and projects.",
  "version": "0.0.1",
  "publisher": "emwaver",
  "icon": "media/emwaver-logo.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:emwaver.buildFlashView",
    "onCommand:emwaver.build",
    "onCommand:emwaver.flash",
    "onCommand:emwaver.openBuildFlash"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "emwaver.openBuildFlash",
        "title": "EMWaver: Open Build & Flash"
      },
      {
        "command": "emwaver.build",
        "title": "EMWaver: Build"
      },
      {
        "command": "emwaver.flash",
        "title": "EMWaver: Flash"
      }
    ],
    "configuration": {
      "title": "EMWaver",
      "properties": {
        "emwaver.cliPath": {
          "type": "string",
          "default": "emwaver",
          "description": "Path to the emwaver CLI executable (or just 'emwaver' if it is on PATH)."
        },
        "emwaver.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for build/flash commands. Leave empty to use the current workspace folder."
        },
        "emwaver.buildArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra args appended to `emwaver build`."
        },
        "emwaver.flashArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra args appended to `emwaver flash`."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "emwaver",
          "title": "EMWaver",
          "icon": "media/emwaver-activity.svg"
        }
      ]
    },
    "views": {
      "emwaver": [
        {
          "id": "emwaver.buildFlashView",
          "name": "Build & Flash",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "emw",
        "aliases": [
          "EMWaver Wavelet",
          "emw"
        ],
        "extensions": [
          ".emw"
        ],
        "mimetypes": [
          "text/javascript"
        ],
        "configuration": "./language-configuration.emw.json"
      }
    ],
    "grammars": [
      {
        "language": "emw",
        "scopeName": "source.emw",
        "path": "./syntaxes/emw.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "emwaver-icons-minimal",
        "label": "EMWaver Icons (minimal)",
        "path": "./emwaver-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4"
  },
  "license": "Apache-2.0"
}
