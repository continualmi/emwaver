#!/usr/bin/env bash
set -euo pipefail

# One-command dev runner for the Gateway CLI/backend.
# - Builds emwaver
# - Runs the emwaver CLI with your args

cd "$(dirname "$0")"

# Fast incremental build
cargo build -q -p emwaver

# Run CLI
if [[ $# -eq 0 ]]; then
  echo "Usage: ./gateway/backend/dev <emwaver-args>"
  echo "Examples:"
  echo "  ./gateway/backend/dev devices"
  echo "  ./gateway/backend/dev gateway"
  echo "  ./gateway/backend/dev gateway status"
  exit 0
fi

exec cargo run -q -p emwaver -- "$@"
