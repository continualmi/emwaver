{
  "name": "emwaver-gateway",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:client && tsx watch src/server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "start": "tsx src/server.ts",
    "start:built": "node dist/server.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "verify": "npm run build:client && npm run typecheck && node scripts/verify.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
