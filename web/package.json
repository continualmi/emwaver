  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "continual-core": "file:../../continual-core",
    "dotenv": "^16.4.5",
    "firebase": "^10.14.1",
    "firebase-admin": "^13.6.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
