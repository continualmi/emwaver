# Repo-wide ignores (keep this file minimal; prefer per-project .gitignore)

# Log files
*.log

# OS
.DS_Store

# ESP-IDF managed components (generated)
managed_components/
adapter/managed_components/

# Editors / IDEs
*.iml
node_modules/
**/.emwaver/

# Vim swap files
*.swp
*.swo
*.swx

# CMake
cmake-build-*/

# Android JNI outputs (generated)
android/app/src/main/jniLibs/

# ESP-IDF build output (generated)
build/
esp/build/

# Backup files
*.bak

# Notes
notes.md

# MkDocs build output (generated; deployed via GitHub Actions)
docs/docs/

# Rust build output (generated)
target/
**/target/

# Library crates don't need lockfiles
cli/crates/**/Cargo.lock
