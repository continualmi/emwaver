# Repo-wide ignores (keep this file minimal; prefer per-project .gitignore)

# Log files
*.log

# OS
.DS_Store

# ESP-IDF managed components (generated)
managed_components/
adapter/managed_components/

# Editors / IDEs
*.iml
node_modules/

# Vim swap files
*.swp
*.swo
*.swx

# CMake
cmake-build-*/

# ESP-IDF build output (generated)
build/
esp/build/

# Backup files
*.bak

# Notes
notes.md
