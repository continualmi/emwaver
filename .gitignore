# Repo-wide ignores (keep this file minimal; prefer per-project .gitignore)

# Log files
*.log

# OS
.DS_Store

# ESP-IDF managed components (generated)
managed_components/
adapter/managed_components/

# Editors / IDEs
*.iml
node_modules/
**/.emwaver/

# Vim swap files
*.swp
*.swo
*.swx

# CMake
cmake-build-*/

# Android JNI outputs (generated)
android/app/src/main/jniLibs/

# ESP-IDF build output (generated)
build/
esp/build/

# Backup files
*.bak

# Notes
notes.md

# MkDocs build output (generated; deployed via GitHub Actions)
docs/docs/

# Rust build output (generated)
target/
**/target/

# STM32CubeIDE Makefile build outputs (generated)
stm/emwaver-firmware/Release/**/*.o
stm/emwaver-firmware/Release/**/*.d
stm/emwaver-firmware/Release/**/*.su
stm/emwaver-firmware/Release/**/*.cyclo
stm/emwaver-firmware/Release/**/*.su
stm/emwaver-firmware/Release/*.elf
stm/emwaver-firmware/Release/*.bin
stm/emwaver-firmware/Release/*.hex
stm/emwaver-firmware/Release/*.map
stm/emwaver-firmware/Release/emwaver-firmware.list
stm/emwaver-firmware/Release/default.size.stdout

stm/emwaver-firmware/Debug/**/*.o
stm/emwaver-firmware/Debug/**/*.d
stm/emwaver-firmware/Debug/**/*.su
stm/emwaver-firmware/Debug/**/*.cyclo
stm/emwaver-firmware/Debug/*.elf
stm/emwaver-firmware/Debug/*.bin
stm/emwaver-firmware/Debug/*.hex
stm/emwaver-firmware/Debug/*.map
stm/emwaver-firmware/Debug/emwaver-firmware.list
stm/emwaver-firmware/Debug/default.size.stdout

# Library crates don't need lockfiles
cli/crates/**/Cargo.lock

# Git worktrees (local developer checkouts)
worktrees/
prompt.txt
