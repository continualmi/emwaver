# Repo-wide ignores (keep this file minimal; prefer per-project .gitignore)

# Sibling EMWaver / *-waver repos (optional local clones; same names as umbrella .gitignore)
/emwaver-air/
/emwaver-carrier/
/emwaver-core/
/emwaver-link/
/emwaver-shield/
/gpio-waver/
/infrared-waver/
/ism-waver/
/rfid-waver/

# Log files
*.log

# OS
.DS_Store

# Local environment
.env
.env.prod
.env.*
!.env.example
.local-secrets/

# ESP-IDF managed components (generated)
managed_components/
adapter/managed_components/

# Editors / IDEs
*.iml
node_modules/
**/.emwaver/

# Python virtualenvs
.venv/

# Python caches
**/__pycache__/
**/*.py[cod]

# Local SQLite databases
**/*.db
**/*.db-journal
**/*.db-shm
**/*.db-wal
**/*.sqlite
**/*.sqlite3

# Vim swap files
*.swp
*.swo
*.swx

# CMake
cmake-build-*/

# Android JNI outputs (generated)
android/app/src/main/jniLibs/

# ESP-IDF build output (generated)
/build/
/esp/build/
tools/emwaver-esp-helper/build/
tools/emwaver-esp-helper/dist/
macos/EMWaver/Tools/emwaver-esp-helper/

# Backup files
*.bak

# Notes
notes.md

# MkDocs build output (generated; deployed via GitHub Actions)
docs/docs/

# Rust build output (generated)
target/
**/target/
target-*/
**/target-*/

# SwiftPM build output (generated)
.build/
**/.build/
.swiftpm/
**/.swiftpm/

# Xcode user/build output (generated)
DerivedData/
**/xcuserdata/
*.xcuserstate

# STM32 USB device target sources (not Rust build output)
!stm/emwaver-firmware/USB_DEVICE/Target/
!stm/emwaver-firmware/USB_DEVICE/Target/**

# STM32CubeIDE project files (generated/IDE-specific)
stm/emwaver-firmware/.cproject
stm/emwaver-firmware/.project
stm/emwaver-firmware/.settings/

# STM32CubeIDE build output directories
# We keep the firmware .elf committed (used as an input to produce the bundled .bin payloads).
# Keep the rest of the build output ignored.
stm/emwaver-firmware/Debug/
stm/emwaver-firmware/Release/
!stm/emwaver-firmware/Release/emwaver-firmware.elf
!stm/emwaver-firmware/Debug/emwaver-firmware.elf


# Library crates don't need lockfiles
crates/**/Cargo.lock

# Git worktrees (local developer checkouts)
worktrees/
.dev-checkouts/
prompt.txt

# Notes (keep tracked)
# notes.txt

# Asset Catalog icon backups
**/AppIcon.appiconset/orig/

# Local branding explorations (generated)
assets/branding/logo-explorations/

# Web auth handoff temp state
web/.data/server/auth-handoff*.json

# Playwright artifacts
.playwright-cli/
output/playwright/
