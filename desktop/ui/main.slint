import { Button, HorizontalBox, VerticalBox, TextEdit, ScrollView, ComboBox, Slider, LineEdit, Switch } from "std-widgets.slint";

export struct ScriptListEntry {
    name: string,
}

export struct ScriptPreviewItem {
    kind: string, // "text" | "button" | "progress" | "picker" | "slider" | "toggle" | "textField" | "textEditor" | "divider" | "spacer"
    id: string,
    text: string,
    token_tap: string,
    token_change: string,
    token_submit: string,
    progress: float,

    // Picker
    picker_index: int,
    options_labels: [string],
    options_values: [string],

    // Slider
    value: float,
    minimum: float,
    maximum: float,
    step: float,

    // Toggle
    checked: bool,

    // Inputs
    input_text: string,
    placeholder: string,
}

export global AppState {
    in-out property <int> page: 0; // 0 = Home, 1 = Editor, 2 = Scripts

    in-out property <string> current_path: "";
    in-out property <string> log_text: "";

    in-out property <[ScriptListEntry]> scripts: [];
    in-out property <string> selected_script: "";
    in-out property <bool> script_running: false;
    in-out property <string> script_error: "";
    in-out property <[ScriptPreviewItem]> script_preview: [];

    in-out property <bool> connected: false;
    in-out property <string> device_name: "";
    in-out property <string> app_version: "";
    in-out property <string> device_version: "";
    in-out property <bool> dfu_connected: false;

    in-out property <bool> update_modal_open: false;
    in-out property <bool> update_in_progress: false;
    in-out property <bool> update_done: false;
    in-out property <string> update_error: "";
    in-out property <int> update_progress_pct: 0;
    in-out property <string> update_progress_message: "";

    callback open_file();
    callback save_file();
    callback run_script();

    callback go_home();
    callback go_editor();
    callback go_scripts();
    callback disconnect();

    callback open_update();
    callback close_update();
    callback start_update();

    callback scripts_refresh();
    callback scripts_select(name: string);
    callback scripts_run();
    callback scripts_stop();
    callback script_invoke0(token: string);
    callback script_invoke_str(token: string, value: string);
    callback script_invoke_num(token: string, value: float);
    callback script_invoke_bool(token: string, value: bool);
}

export component AppWindow inherits Window {
    title: "EMWaver";
    // Use preferred size so the user can resize the window.
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 860px;
    min-height: 600px;

    in-out property <string> editor_text;

    VerticalBox {
        padding: 12px;
        spacing: 10px;

        // Top nav
        HorizontalBox {
            spacing: 8px;

            Button {
                text: "Home";
                clicked => { AppState.go_home(); }
            }
            Button {
                text: "Editor";
                clicked => { AppState.go_editor(); }
            }

            Button {
                text: "Scripts";
                clicked => { AppState.go_scripts(); }
            }

            Text {
                text: "  ";
            }

            Text {
                text: AppState.connected ? "Connected" : (AppState.dfu_connected ? "Update Mode detected" : "Searching...");
                color: AppState.connected ? #2ecc71 : (AppState.dfu_connected ? #f39c12 : #95a5a6);
            }

            Text {
                text: AppState.device_name;
                color: #7f8c8d;
                horizontal-stretch: 1;
                overflow: elide;
            }
        }

        // Home page
        if (AppState.page == 0) : VerticalBox {
            spacing: 10px;

            Rectangle {
                background: #0f1114;
                border-width: 1px;
                border-color: #2b2f36;

                VerticalBox {
                    spacing: 6px;
                    padding: 10px;

                    Text {
                        text: "Device";
                        font-size: 18px;
                        color: #e6e6e6;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "App version:"; color: #a9b1ba; }
                        Text { text: AppState.app_version; color: #e6e6e6; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Device version:"; color: #a9b1ba; }
                        Text { text: AppState.device_version; color: #e6e6e6; }
                    }

                    HorizontalBox {
                        spacing: 10px;
                        Button {
                            text: "Disconnect";
                            enabled: AppState.connected;
                            clicked => { AppState.disconnect(); }
                        }
                        Button {
                            text: "Update device";
                            clicked => { AppState.open_update(); }
                        }
                    }
                }
            }

            TextEdit {
                read-only: true;
                text: AppState.log_text;
                wrap: word-wrap;
                vertical-stretch: 1;
            }
        }

        // Editor page
        if (AppState.page == 1) : VerticalBox {
            spacing: 10px;

            HorizontalBox {
                spacing: 10px;
                alignment: start;

                Button { text: "Open"; clicked => { AppState.open_file(); } }
                Button { text: "Save"; clicked => { AppState.save_file(); } }
                Button { text: "Run"; clicked => { AppState.run_script(); } }

                TextEdit {
                    read-only: true;
                    text: AppState.current_path;
                    horizontal-stretch: 1;
                }
            }

            HorizontalBox {
                spacing: 10px;

                TextEdit {
                    text <=> root.editor_text;
                    wrap: word-wrap;
                    horizontal-stretch: 3;
                    vertical-stretch: 1;
                }

                TextEdit {
                    read-only: true;
                    text: AppState.log_text;
                    wrap: word-wrap;
                    horizontal-stretch: 2;
                    vertical-stretch: 1;
                }
            }
        }

        // Scripts page
        if (AppState.page == 2) : HorizontalBox {
            spacing: 10px;

            // Left: bundled script list
            Rectangle {
                width: 220px;
                background: #0f1114;
                border-width: 1px;
                border-color: #2b2f36;

                VerticalBox {
                    padding: 10px;
                    spacing: 8px;

                    HorizontalBox {
                        spacing: 10px;
                        Text { text: "Scripts"; font-size: 16px; color: #e6e6e6; }
                        Text { text: ""; horizontal-stretch: 1; }
                        Button { text: "Refresh"; clicked => { AppState.scripts_refresh(); } }
                    }

                    Text {
                        text: "Bundled";
                        color: #a9b1ba;
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalBox {
                            spacing: 6px;
                            for entry in AppState.scripts : Button {
                                text: (AppState.selected_script == entry.name ? "> " : "") + entry.name;
                                clicked => { AppState.scripts_select(entry.name); }
                            }
                        }
                    }
                }
            }

            // Main: preview (dominant) + editor (below)
            Rectangle {
                background: #14181f;
                border-width: 1px;
                border-color: #2b2f36;
                horizontal-stretch: 1;

                VerticalBox {
                    padding: 10px;
                    spacing: 8px;

                    HorizontalBox {
                        spacing: 10px;
                        Text { text: "Preview"; font-size: 16px; color: #e6e6e6; }
                        Text { text: AppState.current_path; color: #7f8c8d; horizontal-stretch: 1; overflow: elide; }
                        Button { text: AppState.script_running ? "Stop" : "Run"; clicked => { AppState.script_running ? AppState.scripts_stop() : AppState.scripts_run(); } }
                        Text { text: AppState.script_running ? "Running" : "Idle"; color: AppState.script_running ? #2ecc71 : #a9b1ba; }
                    }

                    if (AppState.script_error != "") : Text {
                        text: AppState.script_error;
                        color: #ff6b6b;
                        wrap: word-wrap;
                    }

                    ScrollView {
                        vertical-stretch: 3;
                        VerticalBox {
                            spacing: 8px;
                            for item in AppState.script_preview : VerticalBox {
                                spacing: 6px;
                                if (item.kind == "text") : Text {
                                    text: item.text;
                                    color: #e6e6e6;
                                    wrap: word-wrap;
                                }
                                if (item.kind == "button") : Button {
                                    text: item.text;
                                    clicked => { if (item.token_tap != "") { AppState.script_invoke0(item.token_tap); } }
                                }
                                if (item.kind == "picker") : VerticalBox {
                                    spacing: 4px;
                                    Text { text: item.text; color: #a9b1ba; }
                                    cb := ComboBox {
                                        model: item.options_labels;
                                        current-index: item.picker_index;
                                        selected(_) => {
                                            if (item.token_change != "") {
                                                AppState.script_invoke_str(item.token_change, item.options_values[cb.current-index]);
                                            }
                                        }
                                    }
                                }
                                if (item.kind == "slider") : VerticalBox {
                                    spacing: 4px;
                                    Text { text: item.text + ": " + item.value; color: #a9b1ba; }
                                    s := Slider {
                                        minimum: item.minimum;
                                        maximum: item.maximum;
                                        step: item.step;
                                        value: item.value;
                                        changed(v) => {
                                            if (item.token_change != "") {
                                                AppState.script_invoke_num(item.token_change, v);
                                            }
                                        }
                                        released => {
                                            if (item.token_submit != "") {
                                                AppState.script_invoke_num(item.token_submit, s.value);
                                            }
                                        }
                                    }
                                }
                                if (item.kind == "toggle") : Switch {
                                    text: item.text;
                                    checked: item.checked;
                                    toggled => {
                                        if (item.token_change != "") {
                                            AppState.script_invoke_bool(item.token_change, self.checked);
                                        }
                                    }
                                }
                                if (item.kind == "textField") : VerticalBox {
                                    spacing: 4px;
                                    Text { text: item.text; color: #a9b1ba; }
                                    i := LineEdit {
                                        placeholder-text: item.placeholder;
                                        text: item.input_text;
                                        edited(txt) => {
                                            if (item.token_change != "") {
                                                AppState.script_invoke_str(item.token_change, txt);
                                            }
                                        }
                                        accepted => {
                                            if (item.token_submit != "") {
                                                AppState.script_invoke_str(item.token_submit, i.text);
                                            }
                                        }
                                    }
                                }
                                if (item.kind == "textEditor") : VerticalBox {
                                    spacing: 4px;
                                    Text { text: item.text; color: #a9b1ba; }
                                    TextEdit {
                                        text: item.input_text;
                                        wrap: word-wrap;
                                        height: 120px;
                                    }
                                    Button {
                                        text: "Submit";
                                        clicked => {
                                            if (item.token_submit != "") {
                                                AppState.script_invoke_str(item.token_submit, item.input_text);
                                            }
                                        }
                                    }
                                }
                                if (item.kind == "divider") : Rectangle {
                                    height: 1px;
                                    background: #2b2f36;
                                }
                                if (item.kind == "spacer") : Rectangle {
                                    height: 10px;
                                    background: transparent;
                                }
                                if (item.kind == "progress") : VerticalBox {
                                    spacing: 4px;
                                    Text { text: item.text; color: #a9b1ba; }
                                    Rectangle {
                                        height: 10px;
                                        background: #2b2f36;
                                        Rectangle {
                                            height: parent.height;
                                            width: parent.width * (item.progress / 100.0);
                                            background: #4aa3ff;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: #2b2f36; }

                    HorizontalBox {
                        spacing: 10px;
                        Text { text: "Script"; font-size: 14px; color: #a9b1ba; }
                        Text { text: ""; horizontal-stretch: 1; }
                    }

                    TextEdit {
                        text <=> root.editor_text;
                        wrap: word-wrap;
                        vertical-stretch: 2;
                    }

                    TextEdit {
                        read-only: true;
                        text: AppState.log_text;
                        wrap: word-wrap;
                        height: 120px;
                    }
                }
            }
        }
    }

    // Update modal overlay
    Rectangle {
        visible: AppState.update_modal_open;
        background: #000000aa;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;

        Rectangle {
            width: 520px;
            height: 320px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #14181f;
            border-width: 1px;
            border-color: #2b2f36;

            VerticalBox {
                padding: 14px;
                spacing: 10px;

                HorizontalBox {
                    spacing: 10px;
                    Text { text: "Update EMWaver"; font-size: 18px; color: #e6e6e6; }
                    Text { text: ""; horizontal-stretch: 1; }
                    Button { text: "Close"; enabled: !AppState.update_in_progress; clicked => { AppState.close_update(); } }
                }

                Text {
                    text: AppState.dfu_connected ? "Device is in Update Mode." : "Put the device into Update Mode, then connect via USB.";
                    color: #a9b1ba;
                    wrap: word-wrap;
                }

                if (AppState.update_error != "") : Text {
                    text: AppState.update_error;
                    color: #ff6b6b;
                    wrap: word-wrap;
                }

                if (AppState.update_done) : Text {
                    text: "Update complete. Unplug, switch to Run, and reconnect.";
                    color: #2ecc71;
                    wrap: word-wrap;
                }

                if (AppState.update_in_progress) : VerticalBox {
                    spacing: 6px;
                    Text { text: AppState.update_progress_message; color: #e6e6e6; wrap: word-wrap; }
                    Rectangle {
                        height: 10px;
                        background: #2b2f36;
                        Rectangle {
                            height: parent.height;
                            width: parent.width * (AppState.update_progress_pct * 1.0 / 100.0);
                            background: #4aa3ff;
                        }
                    }
                    Text { text: AppState.update_progress_pct + "%"; color: #a9b1ba; }
                }

                HorizontalBox {
                    spacing: 10px;
                    Text { text: ""; horizontal-stretch: 1; }
                    Button {
                        text: "Flash firmware";
                        enabled: AppState.dfu_connected && !AppState.update_in_progress;
                        clicked => { AppState.start_update(); }
                    }
                }
            }
        }
    }
}
