              "file": "macos/EMWaver/EMWaver/MacUSBManager.swift",
              "contains": "CoreMIDI[\\s\\S]*MIDIClient"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver/Managers/USBManager.swift",
              "contains": "CoreMIDI[\\s\\S]*MIDIClient"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/UsbMidiSysex.cs",
              "contains": "SysEx|Sysex|MIDI"
            },
            {
              "file": "windows/EMWaver/Services/WindowsDeviceManager.cs",
              "contains": "Midi|MIDI|UsbMidiSysex"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/USBService.java",
