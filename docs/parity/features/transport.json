{
  "component": "transport",
  "features": [
    {
      "id": "transport.ble_runtime",
      "description": "BLE runtime transport exists where the current surface owns device control.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacUSBManager.swift",
              "contains": "CoreBluetooth[\\s\\S]*CBCentralManager[\\s\\S]*bleServiceUUID"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver/Managers/USBManager.swift",
              "contains": "CoreBluetooth[\\s\\S]*CBCentralManager"
            },
            {
              "file": "ios/EMWaver/Managers/BLETransport.swift",
              "contains": "serviceUUID[\\s\\S]*CBUUID"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/WindowsDeviceManager.cs",
              "contains": "BluetoothLEDevice|Gatt|BLE"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/AndroidBleTransport.java",
              "contains": "BluetoothLeScanner|BluetoothGatt[\\s\\S]*SERVICE_UUID"
            }
          ]
        }
      }
    },
    {
      "id": "transport.usb_midi_runtime",
      "description": "USB MIDI runtime transport exists on native device-control apps.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
