{
  "component": "transport",
  "features": [
    {
      "id": "transport.ble_runtime",
      "description": "BLE runtime transport exists where the current surface owns device control.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacUSBManager.swift",
              "contains": "CoreBluetooth[\\s\\S]*CBCentralManager[\\s\\S]*bleServiceUUID"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver/Managers/USBManager.swift",
              "contains": "CoreBluetooth[\\s\\S]*CBCentralManager"
            },
            {
              "file": "ios/EMWaver/Managers/BLETransport.swift",
              "contains": "serviceUUID[\\s\\S]*CBUUID"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/WindowsDeviceManager.cs",
              "contains": "BluetoothLEDevice|Gatt|BLE"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/USBService.java",
              "contains": "BluetoothLeScanner|BluetoothGatt[\\s\\S]*EMW_BLE_SERVICE_UUID"
            }
          ]
        }
      }
    },
    {
      "id": "transport.usb_midi_runtime",
      "description": "USB MIDI runtime transport exists on native device-control apps.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacUSBManager.swift",
              "contains": "CoreMIDI[\\s\\S]*MIDIClient"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver/Managers/USBManager.swift",
              "contains": "CoreMIDI[\\s\\S]*MIDIClient"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/UsbMidiSysex.cs",
              "contains": "SysEx|Sysex|MIDI"
            },
            {
              "file": "windows/EMWaver/Services/WindowsDeviceManager.cs",
              "contains": "Midi|MIDI|UsbMidiSysex"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/USBService.java",
              "contains": "MidiDevice|UsbMidiSysex|MIDI"
            }
          ]
        }
      }
    },
    {
      "id": "transport.wifi_runtime",
      "description": "ESP32 Wi-Fi runtime transport supports local LAN/VPN hardware control through the firmware WebSocket endpoint.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacWiFiManager.swift",
              "contains": [
                "NWBrowser[\\s\\S]*bonjour",
                "URLSessionWebSocketTask",
                "func connect\\(host:"
              ]
            },
            {
              "file": "macos/EMWaver/EMWaver/MacUSBManager.swift",
              "contains": "connectWiFi"
            },
            {
              "file": "macos/EMWaver/EMWaver/DeviceConnectionSheet.swift",
              "contains": [
                "Wi-Fi Setup",
                "wifiHost",
                "wifiPort",
                "provisionWiFi"
              ]
            }
          ]
        },
        "ios": {
          "status": "planned",
          "reason": "iOS has a Wi-Fi transport identity/session boundary, but does not yet expose live ESP32 WebSocket connection, mDNS/manual endpoint UI, or Wi-Fi provisioning in the native app.",
          "evidence": [
            {
              "file": "ios/EMWaver/Managers/WiFiTransport.swift",
              "contains": "Wi-Fi[\\s\\S]*TransportDeviceConnection"
            }
          ]
        },
        "windows": {
          "status": "planned",
          "reason": "Windows has a Wi-Fi transport identity/session boundary, but does not yet expose live ESP32 WebSocket connection, mDNS/manual endpoint UI, or Wi-Fi provisioning in the native app.",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/WindowsWiFiTransport.cs",
              "contains": "Wi-Fi[\\s\\S]*ITransportDeviceConnection"
            }
          ]
        },
        "android": {
          "status": "planned",
          "reason": "Android has a Wi-Fi transport identity/session boundary, but does not yet expose live ESP32 WebSocket connection, mDNS/manual endpoint UI, or Wi-Fi provisioning in the native app.",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/AndroidWiFiTransport.java",
              "contains": "Wi-Fi[\\s\\S]*TransportDeviceConnection"
            }
          ]
        }
      }
    }
  ]
}
