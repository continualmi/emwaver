{
  "component": "agent",
  "features": [
    {
      "id": "agent.api_key.local_storage",
      "description": "Agent API keys are stored locally on every app surface and do not represent an EMWaver account.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            { "file": "macos/EMWaver/EMWaver/Auth/AuthenticationManager.swift", "contains": "KeychainStore\\.setString[\\s\\S]*agent" },
            { "file": "macos/EMWaver/EMWaver/Auth/SignInSheet.swift", "contains": "Agent API Key|Agent API key" }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            { "file": "ios/EMWaver/Auth/AuthenticationManager.swift", "contains": "KeychainStore\\.setString[\\s\\S]*agent" },
            { "file": "ios/EMWaver/Auth/SignInSheet.swift", "contains": "Agent API Key|Agent API key" }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            { "file": "windows/EMWaver/Services/Agent/AgentApiKeyStore.cs", "contains": "SaveApiKeyAsync" },
            { "file": "windows/EMWaver/Dialogs/AccountDialog.xaml", "contains": "Agent API Key|Agent API key" }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            { "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/agent/AgentApiKeyStore.java", "contains": "SharedPreferences[\\s\\S]*api_key" },
            { "file": "android/app/src/main/res/layout/dialog_sign_in.xml", "contains": "Agent API key" }
          ]
        },
        "cli": {
          "status": "planned",
          "reason": "CLI Agent currently uses EMWAVER_AGENT_API_KEY/EMWAVER_AGENT_ENDPOINT environment variables instead of persisted local key storage.",
          "evidence": [
            { "file": "daemon/emwaver/src/main.rs", "contains": "EMWAVER_AGENT_API_KEY[\\s\\S]*EMWAVER_AGENT_ENDPOINT" },
            { "file": "docs/AGENT_API.md", "contains": "CLI uses `EMWAVER_AGENT_API_KEY`" }
          ]
        }
      }
    },
    {
      "id": "agent.chat.local_sqlite",
      "description": "Agent chat conversations and messages are local SQLite-backed state.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            { "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptsUI/AgentChatStore.swift", "contains": "SQLite3[\\s\\S]*agent_conversations[\\s\\S]*agent_messages" }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            { "file": "ios/EMWaver/Views/ScriptsContainerView.swift", "contains": "ScriptsRootView" },
            { "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptsUI/AgentChatStore.swift", "contains": "SQLite3" }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            { "file": "windows/EMWaver/Services/Agent/AgentChatStore.cs", "contains": "Microsoft\\.Data\\.Sqlite[\\s\\S]*agent_conversations[\\s\\S]*agent_messages" }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            { "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/agent/AgentChatStore.java", "contains": "SQLiteOpenHelper[\\s\\S]*agent_conversations[\\s\\S]*agent_messages" }
          ]
        },
        "cli": {
          "status": "not_applicable",
          "reason": "CLI Agent is a single-command helper and does not expose a local chat UI or chat history surface.",
          "evidence": [
            { "file": "daemon/README.md", "contains": "emwaver agent" }
          ]
        }
      }
    },
    {
      "id": "agent.backend_contract",
      "description": "Agent clients send bearer-authenticated MGPT-style universe/userInput requests.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            { "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptsUI/AgentEndpointAPI.swift", "contains": ["Authorization[\\s\\S]*Bearer", "userInput"] }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            { "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptsUI/AgentEndpointAPI.swift", "contains": "universe[\\s\\S]*userInput" }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            { "file": "windows/EMWaver/Services/Agent/AgentApi.cs", "contains": "AuthenticationHeaderValue\\(\"Bearer\"[\\s\\S]*UserInput" }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            { "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/agent/AgentEndpointApi.java", "contains": "Authorization[\\s\\S]*Bearer[\\s\\S]*userInput" }
          ]
        },
        "cli": {
          "status": "required",
          "evidence": [
            { "file": "daemon/emwaver/src/main.rs", "contains": "Authorization[\\s\\S]*Bearer|bearer_auth" },
            { "file": "daemon/emwaver/src/main.rs", "contains": "userInput|user_input|EMWAVER_AGENT_UNIVERSE" }
          ]
        }
      }
    }
  ]
}
