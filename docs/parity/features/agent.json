{
  "component": "agent",
  "features": [
    {
      "id": "agent.api_key.local_storage",
      "description": "Agent API keys are stored locally on app surfaces and do not represent an EMWaver account.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/Auth/AuthenticationManager.swift",
              "contains": "KeychainStore\\.setString[\\s\\S]*agent"
            },
            {
              "file": "macos/EMWaver/EMWaver/Auth/SignInSheet.swift",
              "contains": "Agent API Key|Agent API key"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver/Auth/AuthenticationManager.swift",
              "contains": "KeychainStore\\.setString[\\s\\S]*agent"
            },
            {
              "file": "ios/EMWaver/Auth/SignInSheet.swift",
              "contains": "Agent API Key|Agent API key"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/Agent/AgentApiKeyStore.cs",
              "contains": "SaveApiKeyAsync"
            },
            {
              "file": "windows/EMWaver/Dialogs/AccountDialog.xaml",
              "contains": "Agent API Key|Agent API key"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/agent/AgentApiKeyStore.java",
              "contains": "SharedPreferences[\\s\\S]*api_key"
            },
            {
              "file": "android/app/src/main/res/layout/dialog_sign_in.xml",
              "contains": "Agent API key"
            }
          ]
        }
      }
    },
    {
