          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptsUI/AgentChatStore.swift",
              "contains": "SQLite3"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/Agent/AgentChatStore.cs",
              "contains": "Microsoft\\.Data\\.Sqlite[\\s\\S]*agent_conversations[\\s\\S]*agent_messages"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/agent/AgentChatStore.java",
              "contains": "SQLiteOpenHelper[\\s\\S]*agent_conversations[\\s\\S]*agent_messages"
            }
          ]
        }
      }
    },
