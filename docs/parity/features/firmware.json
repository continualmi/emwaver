{
  "component": "firmware",
  "features": [
    {
      "id": "firmware.stm32_dfu_update",
      "description": "STM32 boards have managed local DFU firmware update paths where supported surfaces own flashing.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/FirmwareUpdateManager.swift",
              "contains": [
                "emwaver-dfu-helper",
                "DFU",
                "firmwareURL"
              ]
            },
            {
              "file": "macos/EMWaver/EMWaver/FirmwareUpdateSheet.swift",
              "contains": "Update Mode|DFU|Firmware"
            }
          ]
        },
        "ios": {
          "status": "not_applicable",
          "reason": "iOS does not expose the USB DFU device class required to own STM32 DFU flashing. iOS parity for this flow is bundled firmware visibility/share plus requesting STM32 Update Mode over an already-local transport.",
          "evidence": [
            {
              "file": "ios/EMWaver/Views/FirmwareUpdateSheet.swift",
              "contains": [
                "Bundled STM32 firmware",
                "Share STM32 firmware",
                "Enter Update Mode",
                "iOS does not expose the full STM32 DFU"
              ]
            },
            {
              "file": "ios/EMWaver/Managers/USBManager.swift",
              "contains": "requestEnterUpdateMode[\\s\\S]*Data\\(\\[0x06\\]\\)"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/FirmwareUpdateManager.cs",
              "contains": "DFU|Dfu|StartUpdate"
            },
            {
              "file": "windows/EMWaver/Views/FirmwareUpdateWindow.xaml.cs",
              "contains": "STM32|DFU|Update Mode"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/ui/emwaver/UpdateDeviceDialogFragment.java",
              "contains": "DFU|flashFirmwareWithDesktopProgress|BUNDLED_FIRMWARE_ASSET_PATH"
            },
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/ui/flash/Dfu.java",
              "contains": "DFU_DNLOAD|DFU_UPLOAD|DFU_GETSTATUS"
            }
          ]
        }
      }
    },
    {
      "id": "firmware.esp32_serial_update",
      "description": "ESP32-family boards use a serial flashing path rather than the STM32 DFU flow.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/FirmwareUpdateManager.swift",
              "contains": [
                "startEspSerialUpdate",
                "emwaver-esp-helper",
                "ESP bootloader"
              ]
            },
            {
              "file": "macos/README.md",
              "contains": "ESP32-S3 update flow|serial flashing"
            }
          ]
        },
        "ios": {
          "status": "not_applicable",
          "reason": "iOS does not own the generic USB serial flashing path required for ESP32-S3 bootloader updates. iOS parity for this flow is bundled ESP firmware visibility/share plus local runtime control over USB MIDI, BLE, or Wi-Fi.",
          "evidence": [
            {
              "file": "ios/EMWaver/Views/FirmwareUpdateSheet.swift",
              "contains": [
                "Share ESP firmware",
                "Bundled ESP image",
                "iOS does not expose the full STM32 DFU or ESP serial flashing runtime"
              ]
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/FirmwareUpdateManager.cs",
              "contains": "ESP|EspBootloader|serial"
            },
            {
              "file": "windows/EMWaver/Views/FirmwareUpdateWindow.xaml",
              "contains": "serial USB|BOOT|RESET"
            },
            {
              "file": "windows/EMWaver/EMWaver.csproj",
              "contains": "emwaver-esp-helper.exe|emwaver-esp32s3-app.bin"
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/ui/emwaver/UpdateDeviceDialogFragment.java",
              "contains": "startEspSerialUpdate|serial bootloader|flashBundledImage"
            },
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/ui/emwaver/EspSerialFirmwareUpdater.java",
              "contains": [
                "assetsForBoardType",
                "FLASH_BEGIN",
                "FLASH_DATA",
                "UsbSerialPort"
              ]
            },
            {
              "file": "android/app/build.gradle",
              "contains": "usb-serial-for-android"
            }
          ]
        }
      }
    }
  ]
}
