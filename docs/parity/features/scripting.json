          "evidence": [{ "file": "macos/EMWaver/EMWaverTests/EMWaverTests.swift", "contains": "import Testing|@Test" }]
        },
        "ios": {
          "status": "planned",
          "reason": "iOS has transport/runtime tests, but the shared simulator fixture test is not yet wired into the iOS target.",
          "evidence": [{ "file": "ios/EMWaverTests/EMWaverTests.swift", "contains": "import Testing|@Test" }]
        },
        "windows": {
          "status": "required",
          "evidence": [{ "file": "windows/EMWaver.Tests/SimulatorScriptEngineTests.cs", "contains": ["SimulatorCommandBridge", "basic-board\\.json"] }]
        },
        "android": {
          "status": "planned",
          "reason": "Android has SimulatorScriptDeviceBridge, but no checked-in JUnit fixture test yet.",
          "evidence": [{ "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/scripts/SimulatorScriptDeviceBridge.java", "contains": "basic-board|fixture|Simulator" }]
        }
      }
    }
  ]
}
