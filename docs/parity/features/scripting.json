{
  "component": "scripting",
  "features": [
    {
      "id": "scripting.default_scripts_packaged",
      "description": "Native app packages include the canonical default .emw script assets and kernel/libraries.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver.xcodeproj/project.pbxproj",
              "contains": [
                "assets/default-scripts",
                "emw-kernel\\.emw",
                "\\*\\.emw"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/ScriptsViewModel.swift",
              "contains": "urls\\(forResourcesWithExtension: \"emw\"[\\s\\S]*DefaultScripts"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver.xcodeproj/project.pbxproj",
              "contains": [
                "assets/default-scripts",
                "emw-kernel\\.emw",
                "\\*\\.emw"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/ScriptsViewModel.swift",
              "contains": "urls\\(forResourcesWithExtension: \"emw\"[\\s\\S]*DefaultScripts"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/EMWaver.csproj",
              "contains": [
                "Assets\\\\DefaultScripts",
                "\\*\\.emw"
              ]
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/build.gradle",
              "contains": [
                "syncScriptAssets",
                "DefaultScripts",
                "include\\(\"\\*\\.emw\"\\)",
                "emw-kernel\\.emw"
              ]
            }
          ]
        },
        "linux": {
          "status": "required",
          "evidence": [
            {
              "file": "linux/crates/emwaver-linux-core/src/script_library.rs",
              "contains": [
                "assets/default-scripts",
                "emw-kernel.emw",
                "EMWAVER_DEFAULT_SCRIPTS_DIR"
              ]
            },
            {
              "file": "linux/scripts/package-linux.sh",
              "contains": "assets/default-scripts/\\*.emw"
            }
          ]
        }
      }
    },
    {
      "id": "scripting.emw_jsx_runtime",
      "description": "Native app script runtimes expose JS imports/require, JSX transpilation, and the shared emw-kernel.emw surface.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptRuntime/ScriptEngine.swift",
              "contains": [
                "emw-kernel\\.emw",
                "require",
                "ScriptModuleTranspiler",
                "ScriptJSXTranspiler"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Tests/EMWaverScriptRuntimeTests/DefaultScriptAssetsTests.swift",
              "contains": "EmwScriptsAndTranspile|ScriptJSXTranspiler"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptRuntime/ScriptEngine.swift",
              "contains": [
                "emw-kernel\\.emw",
                "require",
                "ScriptModuleTranspiler",
                "ScriptJSXTranspiler"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Tests/EMWaverScriptRuntimeTests/DefaultScriptAssetsTests.swift",
              "contains": "EmwScriptsAndTranspile|ScriptJSXTranspiler"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Scripting/ScriptEngine.cs",
              "contains": [
                "emw-kernel\\.emw",
                "function require",
                "ScriptSourceTranspiler\\.Transpile"
              ]
            },
            {
              "file": "windows/EMWaver/Scripting/ScriptSourceTranspiler.cs",
              "contains": [
                "require\\(",
                "JSX\\.h"
              ]
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/scripts/ScriptEngine.java",
              "contains": [
                "emw-kernel\\.emw",
                "require\\(\\)",
                "ScriptSourceTranspiler\\.transpile"
              ]
            },
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/scripts/ScriptSourceTranspiler.java",
              "contains": [
                "require\\(",
                "JSX\\.h"
              ]
            }
          ]
        },
        "linux": {
          "status": "required",
          "evidence": [
            {
              "file": "linux/crates/emwaver-linux-runtime/src/javascript.rs",
              "contains": [
                "execute_javascript_with_modules",
