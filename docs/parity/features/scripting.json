{
  "component": "scripting",
  "features": [
    {
      "id": "scripting.default_scripts_packaged",
      "description": "Native app builds package the canonical default .emw script assets.",
      "parity": "all_required",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [{ "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/FileService.swift", "contains": "DefaultScripts|default-scripts|script_bootstrap" }]
        },
        "ios": {
          "status": "required",
          "evidence": [{ "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/FileService.swift", "contains": "DefaultScripts|script_bootstrap" }]
        },
        "windows": {
          "status": "required",
          "evidence": [{ "file": "windows/EMWaver/EMWaver.csproj", "contains": "SyncDefaultScripts|Assets\\\\DefaultScripts" }]
        },
        "android": {
          "status": "required",
          "evidence": [{ "file": "android/app/build.gradle", "contains": "syncScriptAssets|DefaultScripts|script_bootstrap" }]
        }
      }
    },
    {
      "id": "scripting.simulator_contract_tests",
