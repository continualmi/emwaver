                "JSX.h",
                "emw-protocol.emw"
              ]
            },
            {
              "file": "linux/crates/emwaver-linux-app/src/ui/main_window.rs",
              "contains": [
                "ScriptUiRuntime",
                "execute_javascript_with_modules"
              ]
            }
          ]
        }
      }
    },
