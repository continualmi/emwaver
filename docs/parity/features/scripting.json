{
  "component": "scripting",
  "features": [
    {
      "id": "scripting.default_scripts_packaged",
      "description": "Native app packages include the canonical default .js script assets and kernel/libraries.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver.xcodeproj/project.pbxproj",
              "contains": [
                "assets/default-scripts",
                "emw-kernel\\.js",
                "\\*\\.js"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/ScriptsViewModel.swift",
              "contains": "urls\\(forResourcesWithExtension: \"js\"[\\s\\S]*DefaultScripts"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "ios/EMWaver.xcodeproj/project.pbxproj",
              "contains": [
                "assets/default-scripts",
                "emw-kernel\\.js",
                "\\*\\.js"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptStorage/ScriptsViewModel.swift",
              "contains": "urls\\(forResourcesWithExtension: \"js\"[\\s\\S]*DefaultScripts"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/EMWaver.csproj",
              "contains": [
                "Assets\\\\DefaultScripts",
                "\\*\\.js"
              ]
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/build.gradle",
              "contains": [
                "syncScriptAssets",
                "DefaultScripts",
                "include\\(\"\\*\\.js\"\\)",
                "emw-kernel\\.js"
              ]
            }
          ]
        }
      }
    },
    {
      "id": "scripting.js_jsx_runtime",
      "description": "Native app script runtimes expose JS imports/require, JSX transpilation, and the shared emw-kernel.js surface.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptRuntime/ScriptEngine.swift",
              "contains": [
                "emw-kernel\\.js",
                "require",
                "ScriptModuleTranspiler",
                "ScriptJSXTranspiler"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Tests/EMWaverScriptRuntimeTests/DefaultScriptAssetsTests.swift",
              "contains": "JavaScriptOnlyAndTranspile|ScriptJSXTranspiler"
            }
          ]
        },
        "ios": {
          "status": "required",
          "evidence": [
            {
              "file": "apple/EMWaverAppleCore/Sources/EMWaverScriptRuntime/ScriptEngine.swift",
              "contains": [
                "emw-kernel\\.js",
                "require",
                "ScriptModuleTranspiler",
                "ScriptJSXTranspiler"
              ]
            },
            {
              "file": "apple/EMWaverAppleCore/Tests/EMWaverScriptRuntimeTests/DefaultScriptAssetsTests.swift",
              "contains": "JavaScriptOnlyAndTranspile|ScriptJSXTranspiler"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Scripting/ScriptEngine.cs",
              "contains": [
                "emw-kernel\\.js",
                "function require",
                "ScriptSourceTranspiler\\.Transpile"
              ]
            },
            {
              "file": "windows/EMWaver/Scripting/ScriptSourceTranspiler.cs",
              "contains": [
                "require\\(",
                "JSX\\.h"
              ]
            }
          ]
        },
        "android": {
          "status": "required",
          "evidence": [
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/scripts/ScriptEngine.java",
              "contains": [
                "emw-kernel\\.js",
                "require\\(\\)",
                "ScriptSourceTranspiler\\.transpile"
              ]
            },
            {
              "file": "android/app/src/main/java/com/emwaver/emwaverandroidapp/scripts/ScriptSourceTranspiler.java",
              "contains": [
                "require\\(",
                "JSX\\.h"
              ]
            }
          ]
        }
      }
    },
    {
