{
  "component": "mcp",
  "features": [
    {
      "id": "mcp.desktop_bridge_direction",
      "description": "Desktop apps are the planned local MCP bridge; mobile apps remain local script runners without a listening MCP endpoint.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacMcpServer.swift",
              "contains": [
                "POST",
                "/mcp",
                "Bearer ",
                "tools/list",
                "tools/call"
              ]
            },
            {
              "file": "macos/EMWaver/EMWaver/SettingsView.swift",
              "contains": "Desktop MCP"
            }
          ]
        },
        "ios": {
          "status": "not_applicable",
          "reason": "iOS keeps user script import/app-local execution and does not host an external MCP listener.",
          "evidence": [
            {
              "file": "docs/AGENT_TO_MCP_MIGRATION.html",
              "contains": "iOS / iPadOS</td><td><span class=\"s go\">KEEP</span></td><td><span class=\"s no\">removed</span></td><td>import into app</td><td>"
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/McpServer.cs",
              "contains": [
                "POST",
                "/mcp",
                "Bearer ",
                "tools/list",
                "tools/call"
              ]
            },
            {
              "file": "windows/EMWaver/Views/SettingsWindow.xaml",
              "contains": "Desktop MCP"
            }
          ]
        },
        "android": {
          "status": "not_applicable",
          "reason": "Android keeps user script import/app-local execution and does not host an external MCP listener.",
          "evidence": [
            {
              "file": "docs/AGENT_TO_MCP_MIGRATION.html",
