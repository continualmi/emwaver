{
  "component": "mcp",
  "features": [
    {
      "id": "mcp.desktop_bridge_direction",
      "description": "Desktop apps host the local MCP bridge; mobile apps remain local script runners without a listening MCP endpoint.",
      "parity": "documented_exceptions",
      "platforms": {
        "macos": {
          "status": "required",
          "evidence": [
            {
              "file": "macos/EMWaver/EMWaver/MacMcpServer.swift",
              "contains": [
                "POST",
                "/mcp",
                "Bearer ",
                "tools/list",
                "tools/call"
              ]
            },
            {
              "file": "macos/EMWaver/EMWaver/SettingsView.swift",
              "contains": "Desktop MCP"
            }
          ]
        },
        "ios": {
          "status": "not_applicable",
          "reason": "iOS keeps user script import/app-local execution and does not host an MCP listener.",
          "evidence": [
            {
              "file": "ios/README.md",
              "contains": "iOS keeps local script import/app-local storage and local device/script use without hosting an MCP endpoint."
            }
          ]
        },
        "windows": {
          "status": "required",
          "evidence": [
            {
              "file": "windows/EMWaver/Services/McpServer.cs",
              "contains": [
                "POST",
                "/mcp",
                "Bearer ",
                "tools/list",
                "tools/call"
              ]
            },
            {
              "file": "windows/EMWaver/Views/SettingsWindow.xaml",
              "contains": "Desktop MCP"
            }
          ]
        },
        "android": {
          "status": "not_applicable",
          "reason": "Android keeps user script import/app-local execution and does not host an MCP listener.",
          "evidence": [
            {
              "file": "android/README.md",
              "contains": "Android does not host an MCP server; it keeps local script import/app-local storage and local script execution."
            }
          ]
        },
        "linux": {
          "status": "required",
          "evidence": [
            {
              "file": "linux/crates/emwaver-linux-app/src/ui/mcp_server.rs",
              "contains": [
                "POST",
                "/mcp",
                "Bearer ",
                "tools/list",
                "tools/call"
              ]
            },
            {
              "file": "linux/crates/emwaver-linux-app/src/ui/main_window.rs",
              "contains": "Desktop MCP"
            }
          ]
        }
      }
    },
    {
