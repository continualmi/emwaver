CONFIG_FREERTOS_HZ=1000
CONFIG_ESP8266_DEFAULT_CPU_FREQ_80=y
CONFIG_ESP8266_DEFAULT_CPU_FREQ_MHZ=80
CONFIG_ESP8266_WIFI_AMPDU_RX_ENABLED=n
CONFIG_ESP8266_WIFI_AMPDU_TX_ENABLED=n
CONFIG_LWIP_SO_REUSE=y
CONFIG_ENABLE_MDNS=y
CONFIG_LWIP_IPV6=y
CONFIG_MDNS_MAX_SERVICES=2
CONFIG_MDNS_TASK_PRIORITY=1
CONFIG_MDNS_SERVICE_ADD_TIMEOUT_MS=2000
CONFIG_ESP_PHY_INIT_DATA_VDD33_CONST=33
